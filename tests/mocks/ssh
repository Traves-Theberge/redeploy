#!/usr/bin/env bash
# mock ssh: ssh [opts] <host> "<remote command>"
# Only needs to answer the remote-mode 'redeploy register' call.
a="$*"
case "$a" in
  *"redeploy register"*) printf '{"repo":"testuser/testrepo","runner":"rd-testuser-testrepo","port":8080,"label":"redeploy","registered":true}\n' ;;
  *) exit 0 ;;
esac
