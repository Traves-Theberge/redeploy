#!/usr/bin/env bash
# mock ssh: ssh [opts] <host> "<remote command>"
# Only needs to answer the remote-mode 'pideploy register' call.
a="$*"
case "$a" in
  *"pideploy register"*) printf '{"repo":"testuser/testrepo","runner":"pi-testuser-testrepo","port":8080,"label":"pideploy","registered":true}\n' ;;
  *) exit 0 ;;
esac
