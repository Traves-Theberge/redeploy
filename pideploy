#!/usr/bin/env bash
# pideploy — deploy any git repo to this host on push; visible in Portainer,
# reachable over Tailscale. Plain, non-interactive, scriptable CLI.
#
# Output contract (stable, for scripts & AI agents):
#   - Primary data goes to STDOUT (plain `key=value`/tabular, or JSON with --json).
#   - Progress, warnings, errors go to STDERR, prefixed `pideploy:` / `warn:` / `error:`.
#   - Exit codes: 0 success · 1 runtime error · 2 usage error.
#   - Never prompts. Reads no interactive input.
# Full manual for agents:  pideploy --agent
set -euo pipefail

PIDEPLOY_VERSION="1.0.0"

# ── paths ───────────────────────────────────────────────────────────────────
PIDEPLOY_HOME="${PIDEPLOY_HOME:-$HOME/.pideploy}"
TEMPLATE_DIR="$PIDEPLOY_HOME/runner-template"
RUNNERS_DIR="$PIDEPLOY_HOME/runners"
CONFIG_DIR="${XDG_CONFIG_HOME:-$HOME/.config}/pideploy"
CONFIG_FILE="$CONFIG_DIR/config"
UNIT_DIR="$HOME/.config/systemd/user"
UNIT_NAME="pideploy-runner@.service"
REPO_CONF=".pideploy.conf"

FORMAT=text   # set to 'json' by --json

# ── built-in defaults (overridable by config / repo / flags) ────────────────
declare -A CFG=(
  [default_port]=8080
  [default_branch]=main
  [auto_serve]=false
  [prune_images]=true
  [runner_label]=pideploy
  [node_version]=22
  [python_version]=3.12
  [go_version]=1.23
)

# ── logging (all to stderr; stdout is reserved for data) ────────────────────
# Errors are format-aware: plain `error: msg` in text mode, a JSON object in
# --json mode — always to stderr, with a stable exit code.
log()  { printf 'pideploy: %s\n' "$*" >&2; }
warn() { printf 'warn: %s\n'     "$*" >&2; }
emit_err() { # msg [code]
  if [ "$FORMAT" = json ]; then printf '{"error":%s,"code":%s}\n' "$(json_str "$1")" "${2:-1}" >&2
  else printf 'error: %s\n' "$1" >&2; fi
}
err()  { emit_err "$*" 1; }
die()  { emit_err "$1" "${2:-1}"; exit "${2:-1}"; }
usage_err() { emit_err "$1" 2; exit 2; }

# ── json helpers ─────────────────────────────────────────────────────────────
json_str()  { local s=${1//\\/\\\\}; s=${s//\"/\\\"}; s=${s//$'\n'/\\n}; s=${s//$'\t'/\\t}; s=${s//$'\r'/}; printf '"%s"' "$s"; }
json_bool() { [ "$1" = true ] && printf 'true' || printf 'false'; }

# ── config ──────────────────────────────────────────────────────────────────
_read_conf() { # merge key=value pairs from a file into CFG (set -e safe)
  [ -f "$1" ] || return 0
  local k v
  while IFS='=' read -r k v; do
    [[ "$k" =~ ^[a-z_]+$ ]] && CFG[$k]="$v"
  done < "$1" || true
  return 0
}
load_config() {
  _read_conf "$CONFIG_FILE"
  if git rev-parse --is-inside-work-tree >/dev/null 2>&1; then
    local root; root=$(git rev-parse --show-toplevel)
    _read_conf "$root/$REPO_CONF"
  fi
  return 0
}
cfg() { printf '%s' "${CFG[$1]:-}"; }
config_save() {
  mkdir -p "$CONFIG_DIR"; : > "$CONFIG_FILE"
  local k; for k in "${!CFG[@]}"; do printf '%s=%s\n' "$k" "${CFG[$k]}"; done | sort >> "$CONFIG_FILE"
}

# ── helpers ─────────────────────────────────────────────────────────────────
need() { command -v "$1" >/dev/null 2>&1 || die "missing dependency: $1 (run: pideploy doctor)"; }
repo_slug() { echo "$1" | tr '[:upper:]/' '[:lower:]-' | sed 's/[^a-z0-9-]/-/g'; }
resolve_repo() {
  git rev-parse --is-inside-work-tree >/dev/null 2>&1 || die "not inside a git repo"
  gh repo view --json nameWithOwner -q .nameWithOwner 2>/dev/null \
    || die "no GitHub remote (create one: gh repo create --source=. --private --push)"
}
tailnet_host() { tailscale status --json 2>/dev/null | grep -o '"DNSName":"[^"]*"' | head -1 | cut -d'"' -f4 | sed 's/\.$//'; }
linger_on() { [ "$(loginctl show-user "$USER" -p Linger --value 2>/dev/null)" = yes ]; }

ensure_template() {
  [ -x "$TEMPLATE_DIR/config.sh" ] && return
  mkdir -p "$TEMPLATE_DIR"
  if [ -x "$HOME/actions-runner/config.sh" ]; then
    cp -a "$HOME/actions-runner/." "$TEMPLATE_DIR/"
    rm -rf "$TEMPLATE_DIR/_work" "$TEMPLATE_DIR/.runner" "$TEMPLATE_DIR"/.credentials* 2>/dev/null || true
  else
    local ver arch; ver=$(gh api repos/actions/runner/releases/latest -q .tag_name | sed 's/^v//')
    case "$(uname -m)" in aarch64|arm64) arch=arm64;; x86_64) arch=x64;; *) die "unsupported arch $(uname -m)";; esac
    log "downloading actions runner v$ver ($arch)"
    curl -fsSL -o /tmp/pd-runner.tgz \
      "https://github.com/actions/runner/releases/download/v${ver}/actions-runner-linux-${arch}-${ver}.tar.gz"
    tar xzf /tmp/pd-runner.tgz -C "$TEMPLATE_DIR"; rm -f /tmp/pd-runner.tgz
  fi
}
install_unit() {
  mkdir -p "$UNIT_DIR"
  cat > "$UNIT_DIR/$UNIT_NAME" <<'UNIT'
[Unit]
Description=pideploy GitHub Actions runner (%i)
After=network-online.target docker.service
Wants=network-online.target
[Service]
Type=simple
WorkingDirectory=%h/.pideploy/runners/%i
ExecStart=%h/.pideploy/runners/%i/run.sh
Restart=always
RestartSec=5
KillMode=process
[Install]
WantedBy=default.target
UNIT
  systemctl --user daemon-reload
}
detect_dockerfile() {
  local nv pv gv; nv=$(cfg node_version); pv=$(cfg python_version); gv=$(cfg go_version)
  if   [ -f package.json ]; then printf 'FROM node:%s-slim\nWORKDIR /app\nCOPY package*.json ./\nRUN npm ci --omit=dev || npm install --omit=dev\nCOPY . .\nEXPOSE %s\nCMD ["npm","start"]\n' "$nv" "$(cfg default_port)"
  elif [ -f pyproject.toml ] || [ -f requirements.txt ]; then printf 'FROM python:%s-slim\nWORKDIR /app\nCOPY requirements.txt* pyproject.toml* ./\nRUN pip install --no-cache-dir -r requirements.txt 2>/dev/null || pip install --no-cache-dir . 2>/dev/null || true\nCOPY . .\nEXPOSE %s\nCMD ["python","app.py"]\n' "$pv" "$(cfg default_port)"
  elif [ -f go.mod ]; then printf 'FROM golang:%s AS build\nWORKDIR /src\nCOPY . .\nRUN CGO_ENABLED=0 go build -o /app ./...\nFROM gcr.io/distroless/static\nCOPY --from=build /app /app\nEXPOSE %s\nENTRYPOINT ["/app"]\n' "$gv" "$(cfg default_port)"
  else printf '# TODO: customise for your stack. Serves ./public via nginx by default.\nFROM nginx:alpine\nCOPY public/ /usr/share/nginx/html/\nEXPOSE 80\n'
  fi
}

# ════════════════════════════════════════════════════════════════════════════
# commands
# ════════════════════════════════════════════════════════════════════════════

cmd_init() {
  local port="" name="" do_serve dotenv_name="" want_dotenv=auto; do_serve=$(cfg auto_serve)
  while [ $# -gt 0 ]; do case "$1" in
    --port) port="$2"; shift 2;; --name) name="$2"; shift 2;;
    --serve) do_serve=true; shift;; --no-serve) do_serve=false; shift;;
    --dotenv-secret) dotenv_name="$2"; want_dotenv=yes; shift 2;;
    --no-dotenv) want_dotenv=no; shift;;
    *) usage_err "init: unknown flag: $1";; esac; done
  need git; need gh; need docker
  local nwo slug app branch; nwo=$(resolve_repo); slug=$(repo_slug "$nwo")
  app="${name:-$(cfg app_name)}"; app="${app:-${nwo##*/}}"
  branch=$(cfg default_branch); : "${port:=$(cfg default_port)}"
  log "repo=$nwo app=$app port=$port branch=$branch runner=pi-$slug"

  # secrets: a local .env is the source of truth — synced to a GitHub Actions
  # secret, then recreated in the runner's checkout by the deploy workflow.
  local dotenv_secret=""
  if [ "$want_dotenv" != no ] && [ -f .env ]; then
    dotenv_secret="${dotenv_name:-$(cfg dotenv_secret)}"; dotenv_secret="${dotenv_secret:-PIDEPLOY_DOTENV}"
    CFG[dotenv_secret]="$dotenv_secret"
    if gh secret set "$dotenv_secret" --repo "$nwo" < .env 2>/dev/null; then
      log "synced .env -> GitHub secret $dotenv_secret (source of truth: .env)"
    else warn "could not set secret $dotenv_secret (need admin on $nwo); deploy may lack .env"; fi
  fi

  # scaffold ----------------------------------------------------------------
  local files=()
  if [ -f Dockerfile ]; then log "kept existing Dockerfile"; else detect_dockerfile > Dockerfile; log "wrote Dockerfile"; fi
  files+=(Dockerfile)
  if [ -f docker-compose.yml ] || [ -f compose.yaml ]; then log "kept existing compose file"; else
    cat > docker-compose.yml <<YML
name: $app
services:
  $app:
    build: .
    container_name: $app
    restart: unless-stopped
    ports:
      - "127.0.0.1:${port}:${port}"
YML
    log "wrote docker-compose.yml"
  fi
  files+=(docker-compose.yml)
  mkdir -p .github/workflows
  cat > .github/workflows/deploy.yml <<YML
name: deploy
# SAFETY: only push to your branch + manual dispatch. Do NOT add pull_request —
# on a public repo that lets a fork run code on your self-hosted runner.
on:
  push:
    branches: [$branch]
  workflow_dispatch:
concurrency:
  group: deploy-\${{ github.ref }}
  cancel-in-progress: true
jobs:
  deploy:
    runs-on: [self-hosted, $(cfg runner_label)]
    steps:
      - uses: actions/checkout@v4
$( ds=$(cfg dotenv_secret); [ -n "$ds" ] && printf '      - name: Provision .env from secret\n        env:\n          DOTENV: ${{ secrets.%s }}\n        run: printf '"'"'%%s'"'"' "$DOTENV" > .env' "$ds" )
      - run: docker compose up -d --build --remove-orphans
$( [ "$(cfg prune_images)" = true ] && printf '      - run: docker image prune -f' )
$( ds=$(cfg dotenv_secret); [ -n "$ds" ] && printf '      - name: Remove provisioned .env\n        if: always()\n        run: rm -f .env' )
YML
  files+=(.github/workflows/deploy.yml)
  log "wrote .github/workflows/deploy.yml"
  cat > "$REPO_CONF" <<CONF
# pideploy per-repo config — safe to commit (NO secrets here).
app_name=$app
default_port=$port
default_branch=$branch
CONF
  [ -n "$dotenv_secret" ] && printf 'dotenv_secret=%s\n' "$dotenv_secret" >> "$REPO_CONF"
  files+=("$REPO_CONF")
  log "wrote $REPO_CONF"
  if ! { [ -f .gitignore ] && grep -qE '^\.env$|^\*\.env$|^\.env\*' .gitignore; }; then
    printf '\n# pideploy: never commit secrets\n.env\n*.env\n!*.env.example\n' >> .gitignore
    log "updated .gitignore (.env protected)"
  fi

  # runner ------------------------------------------------------------------
  ensure_template; install_unit
  local registered=false
  if systemctl --user is-active --quiet "pideploy-runner@$slug" >/dev/null 2>&1 \
     || gh api "repos/$nwo/actions/runners" -q '.runners[].name' 2>/dev/null | grep -qx "pi-$slug"; then
    log "runner pi-$slug already registered"
  else
    local rdir="$RUNNERS_DIR/$slug" token
    rm -rf "$rdir"; mkdir -p "$rdir"; cp -a "$TEMPLATE_DIR/." "$rdir/"
    token=$(gh api -X POST "repos/$nwo/actions/runners/registration-token" -q .token) || die "registration token failed (need gh 'repo' scope)"
    ( cd "$rdir" && ./config.sh --unattended --replace --url "https://github.com/$nwo" \
        --token "$token" --name "pi-$slug" --labels "$(cfg runner_label)" --work _work >/dev/null )
    systemctl --user enable --now "pideploy-runner@$slug"
    registered=true
    log "runner pi-$slug installed and started"
  fi
  linger_on || warn "linger is OFF; runners stop on logout/reboot (fix: sudo loginctl enable-linger $USER)"

  # publish -----------------------------------------------------------------
  local f to_add=() pushed=false
  for f in Dockerfile docker-compose.yml compose.yaml .github/workflows/deploy.yml "$REPO_CONF" .gitignore; do
    [ -e "$f" ] && to_add+=("$f")
  done
  [ ${#to_add[@]} -gt 0 ] && git add "${to_add[@]}" 2>/dev/null || true
  if git diff --cached --quiet 2>/dev/null; then
    log "no changes to commit"
  else
    git commit -q -m "Add pideploy: build & deploy on push"
    if git push -q 2>/dev/null; then pushed=true; log "pushed (first deploy starting)"; else warn "committed but push failed; run: git push"; fi
  fi

  # result on stdout --------------------------------------------------------
  if [ "$FORMAT" = json ]; then
    local jf="" sep=""
    for f in "${files[@]}"; do jf+="$sep$(json_str "$f")"; sep=,; done
    printf '{"repo":%s,"app":%s,"port":%s,"branch":%s,"runner":%s,"runner_registered":%s,"pushed":%s,"files":[%s]}\n' \
      "$(json_str "$nwo")" "$(json_str "$app")" "$port" "$(json_str "$branch")" \
      "$(json_str "pi-$slug")" "$(json_bool "$registered")" "$(json_bool "$pushed")" "$jf"
  else
    printf 'repo=%s\napp=%s\nport=%s\nbranch=%s\nrunner=pi-%s\nrunner_registered=%s\npushed=%s\n' \
      "$nwo" "$app" "$port" "$branch" "$slug" "$registered" "$pushed"
  fi
  [ "$do_serve" = true ] && cmd_serve "$port"
  return 0
}

cmd_serve() {
  local port="${1:-}"; [ -n "$port" ] || usage_err "usage: pideploy serve <port>"
  need tailscale
  log "exposing 127.0.0.1:$port over Tailscale (HTTPS)"
  if tailscale serve --bg --https=443 "$port" 2>/tmp/pd.err || sudo -n tailscale serve --bg --https=443 "$port" 2>>/tmp/pd.err; then
    local h url; h=$(tailnet_host); url="https://${h:-localhost}/"
    if [ "$FORMAT" = json ]; then printf '{"url":%s,"port":%s}\n' "$(json_str "$url")" "$port"; else printf '%s\n' "$url"; fi
  else
    local detail; detail=$(tr '\n' ' ' < /tmp/pd.err | sed 's/  */ /g; s/^ *//; s/ *$//')
    warn "if access denied, run once: sudo tailscale set --operator=$USER"
    emit_err "serve failed: ${detail:-unknown}" 1
    return 1
  fi
}

cmd_unserve() {
  local port="${1:-}"; [ -n "$port" ] || usage_err "usage: pideploy unserve <port>"
  tailscale serve --https=443 off 2>/dev/null || sudo -n tailscale serve --https=443 off 2>/dev/null || true
  log "stopped serving (port $port)"
}

cmd_status() {
  # gather ------------------------------------------------------------------
  local rnames=() ractive=() snames=() sstatus=() sports=() serve_lines=() linger=false
  if [ -d "$RUNNERS_DIR" ] && compgen -G "$RUNNERS_DIR/*" >/dev/null; then
    local d s
    for d in "$RUNNERS_DIR"/*/; do s=$(basename "$d"); rnames+=("$s")
      if systemctl --user is-active --quiet "pideploy-runner@$s" >/dev/null 2>&1; then ractive+=(true); else ractive+=(false); fi
    done
  fi
  local line
  while IFS='|' read -r n st pt; do [ -n "$n" ] || continue; snames+=("$n"); sstatus+=("$st"); sports+=("$pt"); done \
    < <(docker ps --format '{{.Names}}|{{.Status}}|{{.Ports}}' 2>/dev/null || true)
  while IFS= read -r line; do [ -n "$line" ] && serve_lines+=("$line"); done \
    < <(tailscale serve status 2>/dev/null | grep -E '^https://' || true)
  linger_on && linger=true

  # emit --------------------------------------------------------------------
  if [ "$FORMAT" = json ]; then
    local i sep out='{"runners":['
    sep=""; for i in "${!rnames[@]}"; do out+="$sep{\"name\":$(json_str "${rnames[$i]}"),\"active\":$(json_bool "${ractive[$i]}")}"; sep=,; done
    out+='],"stacks":['
    sep=""; for i in "${!snames[@]}"; do out+="$sep{\"name\":$(json_str "${snames[$i]}"),\"status\":$(json_str "${sstatus[$i]}"),\"ports\":$(json_str "${sports[$i]}")}"; sep=,; done
    out+='],"serve":['
    sep=""; for i in "${!serve_lines[@]}"; do out+="$sep$(json_str "${serve_lines[$i]}")"; sep=,; done
    out+="],\"linger\":$(json_bool "$linger")}"
    printf '%s\n' "$out"
  else
    local i
    if [ ${#rnames[@]} -eq 0 ]; then printf 'runner\t(none)\n'; else
      for i in "${!rnames[@]}"; do printf 'runner\t%s\t%s\n' "${rnames[$i]}" "$([ "${ractive[$i]}" = true ] && echo active || echo inactive)"; done
    fi
    for i in "${!snames[@]}"; do printf 'stack\t%s\t%s\t%s\n' "${snames[$i]}" "${sstatus[$i]}" "${sports[$i]}"; done
    for i in "${!serve_lines[@]}"; do printf 'serve\t%s\n' "${serve_lines[$i]}"; done
    printf 'linger\t%s\n' "$([ "$linger" = true ] && echo enabled || echo disabled)"
  fi
}

cmd_logs() {
  local app="${1:-}"
  [ -z "$app" ] && app=$(docker ps --format '{{.Names}}' | head -1)
  [ -z "$app" ] && die "no running containers"
  exec docker logs -f --tail 100 "$app"
}

cmd_deploy() {
  local nwo; nwo=$(resolve_repo)
  if gh workflow run deploy.yml 2>/dev/null; then
    log "deploy dispatched for $nwo"
    [ "$FORMAT" = json ] && printf '{"dispatched":true,"repo":%s}\n' "$(json_str "$nwo")" || printf 'dispatched=true\n'
  else
    warn "workflow_dispatch failed; pushing empty commit"
    git commit -q --allow-empty -m "pideploy: trigger deploy" && git push -q
    log "pushed empty commit"
    [ "$FORMAT" = json ] && printf '{"dispatched":true,"method":"push","repo":%s}\n' "$(json_str "$nwo")" || printf 'dispatched=true\n'
  fi
}

cmd_env() { # sync local .env (source of truth) to a GitHub Actions secret
  local name=""
  while [ $# -gt 0 ]; do case "$1" in --name) name="$2"; shift 2;; *) usage_err "env: unknown flag: $1";; esac; done
  need gh
  local nwo; nwo=$(resolve_repo)
  [ -f .env ] || die "no .env in this repo (the source of truth for secrets)"
  local secret="${name:-$(cfg dotenv_secret)}"; secret="${secret:-PIDEPLOY_DOTENV}"
  gh secret set "$secret" --repo "$nwo" < .env || die "gh secret set failed (need admin on $nwo)"
  log "synced .env -> GitHub secret $secret for $nwo"
  if [ "$FORMAT" = json ]; then printf '{"secret":%s,"repo":%s}\n' "$(json_str "$secret")" "$(json_str "$nwo")"
  else printf 'secret=%s\n' "$secret"; fi
}

cmd_config() {
  local sub="${1:-list}"; shift || true
  case "$sub" in
    list|"")
      if [ "$FORMAT" = json ]; then
        local k sep out='{'; sep=""
        for k in $(printf '%s\n' "${!CFG[@]}" | sort); do out+="$sep$(json_str "$k"):$(json_str "${CFG[$k]}")"; sep=,; done
        printf '%s}\n' "$out"
      else
        local k; for k in $(printf '%s\n' "${!CFG[@]}" | sort); do printf '%s=%s\n' "$k" "${CFG[$k]}"; done
      fi ;;
    get) [ -n "${1:-}" ] || usage_err "usage: pideploy config get <key>"; printf '%s\n' "$(cfg "$1")" ;;
    set) [ -n "${1:-}" ] && [ -n "${2:-}" ] || usage_err "usage: pideploy config set <key> <value>"
         CFG[$1]="$2"; config_save; log "set $1=$2" ;;
    edit) mkdir -p "$CONFIG_DIR"; [ -f "$CONFIG_FILE" ] || config_save; "${EDITOR:-nano}" "$CONFIG_FILE" ;;
    *) usage_err "config: list | get <k> | set <k> <v> | edit" ;;
  esac
}

cmd_rm() {
  local nwo slug; nwo=$(resolve_repo); slug=$(repo_slug "$nwo")
  systemctl --user disable --now "pideploy-runner@$slug" 2>/dev/null || true
  local rdir="$RUNNERS_DIR/$slug" token
  if [ -x "$rdir/config.sh" ]; then
    token=$(gh api -X POST "repos/$nwo/actions/runners/remove-token" -q .token 2>/dev/null || true)
    [ -n "$token" ] && ( cd "$rdir" && ./config.sh remove --token "$token" >/dev/null 2>&1 || true )
  fi
  rm -rf "$rdir"
  log "removed runner pi-$slug (workflow file kept in repo)"
  printf 'removed=pi-%s\n' "$slug"
}

cmd_setup() {
  log "one-time host prep (idempotent)"
  if linger_on; then log "linger: already enabled"
  elif sudo -n loginctl enable-linger "$USER" 2>/dev/null; then log "linger: enabled"
  else warn "linger: run manually -> sudo loginctl enable-linger $USER"; fi
  if sudo -n tailscale set --operator="$USER" 2>/dev/null; then log "tailscale operator: set to $USER"
  else warn "tailscale operator: run manually -> sudo tailscale set --operator=$USER"; fi
  log "now run: pideploy doctor"
}

cmd_doctor() {
  local names=() oks=() sev=() allok=true
  add() { names+=("$1"); oks+=("$2"); sev+=("${3:-fatal}")
          [ "$2" = true ] || { [ "${3:-fatal}" = fatal ] && allok=false; }; return 0; }
  local b; for b in git gh docker curl tar systemctl loginctl tailscale; do
    command -v "$b" >/dev/null 2>&1 && add "$b" true || add "$b" false
  done
  gh auth status >/dev/null 2>&1 && add gh-auth true || add gh-auth false
  id -nG | tr ' ' '\n' | grep -qx docker && add docker-group true || add docker-group false
  systemctl --user is-system-running >/dev/null 2>&1 && add user-systemd true || add user-systemd false
  docker info >/dev/null 2>&1 && add docker-engine true || add docker-engine false
  command -v tailscale >/dev/null 2>&1 && { tailscale status >/dev/null 2>&1 && add tailscale-up true || add tailscale-up false warn; }
  linger_on && add linger true || add linger false warn

  local i
  if [ "$FORMAT" = json ]; then
    local sep out='{"checks":['
    sep=""; for i in "${!names[@]}"; do out+="$sep{\"name\":$(json_str "${names[$i]}"),\"ok\":$(json_bool "${oks[$i]}"),\"severity\":$(json_str "${sev[$i]}")}"; sep=,; done
    out+="],\"ok\":$(json_bool "$allok")}"; printf '%s\n' "$out"
  else
    for i in "${!names[@]}"; do
      if [ "${oks[$i]}" = true ]; then printf '%-16s ok\n' "${names[$i]}"
      elif [ "${sev[$i]}" = warn ]; then printf '%-16s WARN\n' "${names[$i]}"
      else printf '%-16s FAIL\n' "${names[$i]}"; fi
    done
  fi
  [ "$allok" = true ] || return 1
}

# ── agent manual ─────────────────────────────────────────────────────────────
cmd_agent() {
  cat <<'AGENT'
# pideploy — Agent Operating Manual

Deploys any git repo to this host: on every push, a self-hosted GitHub Actions
runner builds the repo's Docker image and runs it via docker compose. Containers
appear in Portainer (same Docker engine) and can be exposed on the tailnet over
HTTPS. This CLI is plain and non-interactive.

## Output contract
- Primary data -> STDOUT. Plain `key=value` or tab-separated rows; add `--json`
  for structured JSON on: init, status, deploy, serve, config, doctor.
- Progress/warnings/errors -> STDERR (`pideploy:` / `warn:` / `error:`). In `--json`
  mode, errors are a JSON object on STDERR: `{"error":"<msg>","code":<N>}`. On any
  error STDOUT stays empty.
- Exit codes: 0 ok · 1 runtime error · 2 usage error.
- Never prompts; reads no stdin. Safe to run unattended.

## Architecture
- One self-hosted runner per repo, as user systemd service
  `pideploy-runner@<owner-repo>` (no root; needs `loginctl enable-linger` once).
- Runner connects OUTBOUND to GitHub, so the host needs no inbound ports and
  works tailnet-only. GitHub webhooks cannot reach it — do not use them.
- Deploys run `docker compose up -d --build`; Portainer shares the Docker engine.
- Exposure: `tailscale serve --https=443 <port>`; apps bind 127.0.0.1 only.

## How the deploy is routed (no address/SSH — label matching)
There is NO IP, hostname, SSH key, or target in the repo. `init` registers a
runner on THIS host with GitHub, labeled `[self-hosted, Linux, <arch>, <runner_label>]`.
The workflow's `runs-on: [self-hosted, <runner_label>]` is a label requirement, not
an address; GitHub dispatches the job to the matching runner — i.e. this host.
Move the runner elsewhere and the same push deploys there; the repo is unchanged.

## Deploy pipeline (runs on the host for each push to the branch)
1. `actions/checkout@v4` — clone the repo into the runner workdir.
2. (if a .env secret is configured) Provision .env: `printf '%s' "$DOTENV" > .env`
   where DOTENV=`secrets.<NAME>` (GitHub-masked).
3. `docker compose up -d --build --remove-orphans` — build + (re)start containers.
4. `docker image prune -f` (if prune_images) — drop dangling layers.
5. (if .env secret) Remove provisioned .env with `if: always()`.
Result: containers run on the host's Docker engine (visible in Portainer);
`pideploy serve <port>` exposes one over Tailscale HTTPS.

## Prerequisites (verify: `pideploy doctor`, or `pideploy doctor --json`)
- gh authenticated, scopes `repo` + `workflow`.
- user in `docker` group; user systemd running; docker engine reachable.
- `sudo loginctl enable-linger $USER` (persist runners) — or run `pideploy setup`.
- tailscale up; `sudo tailscale set --operator=$USER` (serve without sudo).

## Commands
- `pideploy setup` — best-effort one-time host prep (linger, tailscale operator).
- `pideploy doctor [--json]` — prerequisite check; exit 1 if any fatal check fails.
- `pideploy init [--port N] [--name NAME] [--serve] [--json]` — in a git repo with
  a GitHub remote: scaffold Dockerfile/compose/workflow + `.pideploy.conf`,
  register+start the runner, commit & push. Emits repo/app/port/runner/pushed.
- `pideploy deploy [--json]` — trigger a deploy now.
- `pideploy status [--json]` — runners, stacks, serve, linger.
- `pideploy serve <port> [--json]` — expose a port; prints the https URL on stdout.
- `pideploy unserve <port>` — stop exposing.
- `pideploy logs [app]` — exec `docker logs -f` (stdout passthrough).
- `pideploy config [list|get <k>|set <k> <v>|edit] [--json]` — manage defaults.
- `pideploy env [--name NAME] [--json]` — sync local .env to a GitHub Actions secret.
- `pideploy rm` — deregister this repo's runner.
- `pideploy skill` — print a Claude Code skill for this CLI (also: `--skill`).
- `pideploy help [command]` — overview, or detailed help + options for one command.
- `pideploy version` · `pideploy --agent` (print this manual).

Global flags: `--json` (structured output), `--agent` (this manual), `--skill`
(the skill), `--yes` (accepted, no-op).

## Config & precedence
Flags > per-repo `.pideploy.conf` > global `$XDG_CONFIG_HOME/pideploy/config` > built-in.
Keys: default_port, default_branch, auto_serve, prune_images, runner_label,
node_version, python_version, go_version, app_name (repo-level).

## Files written into a repo by init
- `Dockerfile` (only if missing; node/python/go/static autodetect).
- `docker-compose.yml` (build: ., binds 127.0.0.1:<port>, top-level name:=stack).
- `.github/workflows/deploy.yml` (runs-on [self-hosted, <label>]; push + dispatch only).
- `.pideploy.conf` (port/name/branch; safe to commit, no secrets).
- appends `.env` to `.gitignore`.

## Secrets (.env)
A local `.env` is the source of truth. When present, `init` uploads it to a GitHub
Actions secret (`gh secret set`, default name PIDEPLOY_DOTENV) and the generated
workflow recreates `.env` on the runner before `docker compose up`. `.env` is never
committed. Re-sync after editing it with `pideploy env`. Skip with `--no-dotenv`.

## Agent quickstart (deploy a repo end-to-end)
1. cd <repo>  (needs GitHub remote; else: gh repo create --source=. --private --push)
2. pideploy doctor --json    # ensure "ok":true; if not, pideploy setup
3. pideploy init --port <app-port> --json
4. pideploy status --json    # confirm runner active and a stack is up
5. pideploy serve <app-port> # stdout is the https URL
Redeploy after changes: git push   (or: pideploy deploy)

## Troubleshooting
- runner inactive: systemctl --user status pideploy-runner@<owner-repo>; enable linger.
- unreachable app: ensure it listens on <port> and compose maps 127.0.0.1:<port>:<port>.
- serve "access denied": sudo tailscale set --operator=$USER.
- no remote / push rejected: gh repo create first; check gh scopes repo+workflow.
AGENT
}

