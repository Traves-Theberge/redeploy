#!/usr/bin/env bash
# pideploy — deploy any git repo to this host on push; visible in Portainer,
# reachable over Tailscale. Plain, non-interactive, scriptable CLI.
#
# Output contract (stable, for scripts & AI agents):
#   - Primary data goes to STDOUT (plain `key=value`/tabular, or JSON with --json).
#   - Progress, warnings, errors go to STDERR, prefixed `pideploy:` / `warn:` / `error:`.
#   - Exit codes: 0 success · 1 runtime error · 2 usage error.
#   - Never prompts. Reads no interactive input.
# Full manual for agents:  pideploy --agent
set -euo pipefail

PIDEPLOY_VERSION="1.2.0"

# ── paths ───────────────────────────────────────────────────────────────────
PIDEPLOY_HOME="${PIDEPLOY_HOME:-$HOME/.pideploy}"
TEMPLATE_DIR="$PIDEPLOY_HOME/runner-template"
RUNNERS_DIR="$PIDEPLOY_HOME/runners"
PORTS_FILE="$PIDEPLOY_HOME/ports"   # host-wide registry: <owner-repo>=<port> (no collisions)
CONFIG_DIR="${XDG_CONFIG_HOME:-$HOME/.config}/pideploy"
CONFIG_FILE="$CONFIG_DIR/config"
UNIT_DIR="$HOME/.config/systemd/user"
UNIT_NAME="pideploy-runner@.service"
REPO_CONF=".pideploy.conf"

FORMAT=text   # set to 'json' by --json

# ── built-in defaults (overridable by config / repo / flags) ────────────────
# Host-level settings live in ~/.config/pideploy/config (one config, many repos).
# Generate a shareable placeholder with: pideploy config template
declare -A CFG=(
  [deploy_host]=""              # friendly name for this target host (e.g. my-pi)
  [portainer_url]=""            # Portainer URL on this host (reference/links; deploy is via compose)
  [runner_label]=pideploy       # label that routes GitHub Actions jobs to this host's runner
  [default_port]=8080
  [default_branch]=main
  [auto_serve]=false
  [prune_images]=true
  [node_version]=22
  [python_version]=3.12
  [go_version]=1.23
)

# ── logging (all to stderr; stdout is reserved for data) ────────────────────
# Errors are format-aware: plain `error: msg` in text mode, a JSON object in
# --json mode — always to stderr, with a stable exit code.
log()  { printf 'pideploy: %s\n' "$*" >&2; }
warn() { printf 'warn: %s\n'     "$*" >&2; }
emit_err() { # msg [code]
  if [ "$FORMAT" = json ]; then printf '{"error":%s,"code":%s}\n' "$(json_str "$1")" "${2:-1}" >&2
  else printf 'error: %s\n' "$1" >&2; fi
}
err()  { emit_err "$*" 1; }
die()  { emit_err "$1" "${2:-1}"; exit "${2:-1}"; }
usage_err() { emit_err "$1" 2; exit 2; }

# ── json helpers ─────────────────────────────────────────────────────────────
json_str()  { local s=${1//\\/\\\\}; s=${s//\"/\\\"}; s=${s//$'\n'/\\n}; s=${s//$'\t'/\\t}; s=${s//$'\r'/}; printf '"%s"' "$s"; }
json_bool() { [ "$1" = true ] && printf 'true' || printf 'false'; }

# ── config ──────────────────────────────────────────────────────────────────
_read_conf() { # merge key=value pairs from a file into CFG (set -e safe)
  [ -f "$1" ] || return 0
  local k v
  while IFS='=' read -r k v; do
    [[ "$k" =~ ^[a-z_]+$ ]] && CFG[$k]="$v"
  done < "$1" || true
  return 0
}
load_config() {
  _read_conf "$CONFIG_FILE"
  if git rev-parse --is-inside-work-tree >/dev/null 2>&1; then
    local root; root=$(git rev-parse --show-toplevel)
    _read_conf "$root/$REPO_CONF"
  fi
  return 0
}
cfg() { printf '%s' "${CFG[$1]:-}"; }
config_save() {
  mkdir -p "$CONFIG_DIR"; : > "$CONFIG_FILE"
  local k; for k in "${!CFG[@]}"; do printf '%s=%s\n' "$k" "${CFG[$k]}"; done | sort >> "$CONFIG_FILE"
}

# ── port registry (one host, many repos, no collisions) ─────────────────────
port_reg_get() { [ -f "$PORTS_FILE" ] && awk -F= -v s="$1" '$1==s{print $2; exit}' "$PORTS_FILE" || true; }
port_reg_set() { # slug port  — upsert
  local s="$1" p="$2" tmp; mkdir -p "$PIDEPLOY_HOME"; tmp=$(mktemp)
  { [ -f "$PORTS_FILE" ] && grep -v "^$s=" "$PORTS_FILE"; printf '%s=%s\n' "$s" "$p"; } > "$tmp" 2>/dev/null || true
  mv "$tmp" "$PORTS_FILE"
}
port_reg_del() { # slug
  [ -f "$PORTS_FILE" ] || return 0
  local tmp; tmp=$(mktemp); grep -v "^$1=" "$PORTS_FILE" > "$tmp" 2>/dev/null || true; mv "$tmp" "$PORTS_FILE"
}
port_in_use() { # port [exclude-slug] [exclude-app]  -> 0 if taken by ANOTHER repo/container
  local p="$1" xslug="${2:-}" xapp="${3:-}" s pp
  if [ -f "$PORTS_FILE" ]; then
    while IFS='=' read -r s pp; do
      [ "$s" = "$xslug" ] && continue
      [ "$pp" = "$p" ] && return 0
    done < "$PORTS_FILE"
  fi
  # bound on the host right now by a DIFFERENT container?
  docker ps --format '{{.Names}}|{{.Ports}}' 2>/dev/null \
    | awk -F'|' -v port=":$p->" -v self="$xapp" '$2 ~ port && $1 != self {f=1} END{exit !f}' && return 0
  return 1
}
port_alloc() { # [exclude-slug] [exclude-app]  -> lowest free port at/above default_port
  local xslug="${1:-}" xapp="${2:-}" start p
  start=$(cfg default_port); [[ "$start" =~ ^[0-9]+$ ]] || start=8080
  for (( p=start; p<=start+999; p++ )); do
    port_in_use "$p" "$xslug" "$xapp" || { printf '%s' "$p"; return 0; }
  done
  die "no free port found in ${start}-$((start+999))"
}

# ── helpers ─────────────────────────────────────────────────────────────────
need() { command -v "$1" >/dev/null 2>&1 || die "missing dependency: $1 (run: pideploy doctor)"; }
# Refuse to commit with a missing or generic/placeholder git identity. A blank or
# shared address (e.g. noreply@users.noreply.github.com) gets mis-attributed by
# GitHub to whatever account claimed it — so pin a real identity before committing.
require_git_identity() {
  local name email; name=$(git config user.name 2>/dev/null); email=$(git config user.email 2>/dev/null)
  [ -n "$email" ] || die "git user.email not set — run: git config --global user.email you@example.com" 2
  [ -n "$name" ]  || die "git user.name not set — run: git config --global user.name 'Your Name'" 2
  case "$email" in
    *noreply@users.noreply.github.com)
      die "refusing to commit as the generic '$email' — GitHub mis-links it to a stranger's account. Set yours: git config --global user.email you@example.com" 2 ;;
    *@*.*) : ;;  # looks like a real address
    *) die "git user.email '$email' is not a valid address — run: git config --global user.email you@example.com" 2 ;;
  esac
}
repo_slug() { echo "$1" | tr '[:upper:]/' '[:lower:]-' | sed 's/[^a-z0-9-]/-/g'; }
resolve_repo() {
  git rev-parse --is-inside-work-tree >/dev/null 2>&1 || die "not inside a git repo"
  gh repo view --json nameWithOwner -q .nameWithOwner 2>/dev/null \
    || die "no GitHub remote (create one: gh repo create --source=. --private --push)"
}
tailnet_host() { # robust to pretty-printed JSON ("DNSName": "x"); never fails the pipeline
  tailscale status --json 2>/dev/null | tr -d ' ' | grep -oE '"DNSName":"[^"]+"' | head -1 | cut -d'"' -f4 | sed 's/\.$//'
  return 0
}
linger_on() { [ "$(loginctl show-user "$USER" -p Linger --value 2>/dev/null)" = yes ]; }

ensure_template() {
  [ -x "$TEMPLATE_DIR/config.sh" ] && return
  mkdir -p "$TEMPLATE_DIR"
  if [ -x "$HOME/actions-runner/config.sh" ]; then
    cp -a "$HOME/actions-runner/." "$TEMPLATE_DIR/"
    rm -rf "$TEMPLATE_DIR/_work" "$TEMPLATE_DIR/.runner" "$TEMPLATE_DIR"/.credentials* 2>/dev/null || true
  else
    local ver arch; ver=$(gh api repos/actions/runner/releases/latest -q .tag_name | sed 's/^v//')
    case "$(uname -m)" in aarch64|arm64) arch=arm64;; x86_64) arch=x64;; *) die "unsupported arch $(uname -m)";; esac
    log "downloading actions runner v$ver ($arch)"
    curl -fsSL -o /tmp/pd-runner.tgz \
      "https://github.com/actions/runner/releases/download/v${ver}/actions-runner-linux-${arch}-${ver}.tar.gz"
    tar xzf /tmp/pd-runner.tgz -C "$TEMPLATE_DIR"; rm -f /tmp/pd-runner.tgz
  fi
}
install_unit() {
  mkdir -p "$UNIT_DIR"
  cat > "$UNIT_DIR/$UNIT_NAME" <<'UNIT'
[Unit]
Description=pideploy GitHub Actions runner (%i)
After=network-online.target docker.service
Wants=network-online.target
[Service]
Type=simple
WorkingDirectory=%h/.pideploy/runners/%i
ExecStart=%h/.pideploy/runners/%i/run.sh
Restart=always
RestartSec=5
KillMode=process
[Install]
WantedBy=default.target
UNIT
  systemctl --user daemon-reload
}
detect_dockerfile() {
  local nv pv gv; nv=$(cfg node_version); pv=$(cfg python_version); gv=$(cfg go_version)
  if   [ -f package.json ]; then printf 'FROM node:%s-slim\nWORKDIR /app\nCOPY package*.json ./\nRUN npm ci --omit=dev || npm install --omit=dev\nCOPY . .\nEXPOSE %s\nCMD ["npm","start"]\n' "$nv" "$(cfg default_port)"
  elif [ -f pyproject.toml ] || [ -f requirements.txt ]; then printf 'FROM python:%s-slim\nWORKDIR /app\nCOPY requirements.txt* pyproject.toml* ./\nRUN pip install --no-cache-dir -r requirements.txt 2>/dev/null || pip install --no-cache-dir . 2>/dev/null || true\nCOPY . .\nEXPOSE %s\nCMD ["python","app.py"]\n' "$pv" "$(cfg default_port)"
  elif [ -f go.mod ]; then printf 'FROM golang:%s AS build\nWORKDIR /src\nCOPY . .\nRUN CGO_ENABLED=0 go build -o /app ./...\nFROM gcr.io/distroless/static\nCOPY --from=build /app /app\nEXPOSE %s\nENTRYPOINT ["/app"]\n' "$gv" "$(cfg default_port)"
  else printf '# TODO: customise for your stack. Serves ./public via nginx by default.\nFROM nginx:alpine\nCOPY public/ /usr/share/nginx/html/\nEXPOSE 80\n'
  fi
}

# ════════════════════════════════════════════════════════════════════════════
# commands
# ════════════════════════════════════════════════════════════════════════════

cmd_init() {
  local port="" name="" do_serve dotenv_name="" want_dotenv=auto; do_serve=$(cfg auto_serve)
  while [ $# -gt 0 ]; do case "$1" in
    --port) port="$2"; shift 2;; --name) name="$2"; shift 2;;
    --serve) do_serve=true; shift;; --no-serve) do_serve=false; shift;;
    --dotenv-secret) dotenv_name="$2"; want_dotenv=yes; shift 2;;
    --no-dotenv) want_dotenv=no; shift;;
    *) usage_err "init: unknown flag: $1";; esac; done
  need git; need gh
  local nwo slug app branch; nwo=$(resolve_repo); slug=$(repo_slug "$nwo")
  app="${name:-$(cfg app_name)}"; app="${app:-${nwo##*/}}"
  branch=$(cfg default_branch)

  # The runner lives on the DEPLOY HOST. Resolve port + label + register it:
  #  - local mode:  this machine IS the host (register here).
  #  - remote mode: cfg runner_host set -> register on the host over SSH, which
  #    returns the assigned port + label. init then only scaffolds + pushes, so
  #    it runs fine on a laptop with no Docker/systemd.
  local rhost label registered=false; rhost=$(cfg runner_host)
  if [ -n "$rhost" ]; then
    need ssh
    log "registering runner on $rhost over SSH (remote mode)"
    local reg
    reg=$(ssh -o BatchMode=yes "$rhost" "bash -lc 'pideploy register $nwo ${port:+--port $port} --json'" 2>/tmp/pd.ssh) \
      || die "remote registration failed (ssh $rhost): $(tr '\n' ' ' </tmp/pd.ssh | sed 's/  */ /g; s/^ *//'). Ensure Tailscale SSH is on and pideploy is installed on the host."
    port=$(printf '%s' "$reg" | grep -oE '"port":[0-9]+' | head -1 | cut -d: -f2)
    label=$(printf '%s' "$reg" | grep -oE '"label":"[^"]*"' | head -1 | cut -d'"' -f4)
    { [ -n "$port" ] && [ -n "$label" ]; } || die "unexpected response from host: $reg"
    registered=true
  else
    need docker
    # port: explicit (collision-guarded) > recorded for this repo > auto-allocated.
    local recorded; recorded=$(port_reg_get "$slug")
    if [ -n "$port" ]; then
      port_in_use "$port" "$slug" "$app" && die "port $port is already in use by another app on this host (omit --port to auto-assign a free one, e.g. $(port_alloc "$slug" "$app"))"
    elif [ -n "$recorded" ]; then port="$recorded"
    else port=$(port_alloc "$slug" "$app"); fi
    port_reg_set "$slug" "$port"
    label=$(cfg runner_label)
    if runner_register "$nwo" "$slug"; then registered=true; log "runner pi-$slug installed and started"
    else log "runner pi-$slug already registered"; fi
    linger_on || warn "linger is OFF; runners stop on logout/reboot (fix: sudo loginctl enable-linger $USER)"
  fi
  log "repo=$nwo app=$app port=$port branch=$branch runner=pi-$slug label=$label"

  # secrets: a local .env is the source of truth — synced to a GitHub Actions
  # secret, then recreated in the runner's checkout by the deploy workflow.
  local dotenv_secret=""
  if [ "$want_dotenv" != no ] && [ -f .env ]; then
    dotenv_secret="${dotenv_name:-$(cfg dotenv_secret)}"; dotenv_secret="${dotenv_secret:-PIDEPLOY_DOTENV}"
    CFG[dotenv_secret]="$dotenv_secret"
    if gh secret set "$dotenv_secret" --repo "$nwo" < .env 2>/dev/null; then
      log "synced .env -> GitHub secret $dotenv_secret (source of truth: .env)"
    else warn "could not set secret $dotenv_secret (need admin on $nwo); deploy may lack .env"; fi
  fi

  # scaffold ----------------------------------------------------------------
  local files=()
  if [ -f Dockerfile ]; then log "kept existing Dockerfile"; else detect_dockerfile > Dockerfile; log "wrote Dockerfile"; fi
  files+=(Dockerfile)
  if [ -f docker-compose.yml ] || [ -f compose.yaml ]; then log "kept existing compose file"; else
    cat > docker-compose.yml <<YML
name: $app
services:
  $app:
    build: .
    container_name: $app
    restart: unless-stopped
    environment:
      - PORT=${port}            # apps that respect \$PORT listen on the assigned port
    ports:
      - "127.0.0.1:${port}:${port}"
YML
    log "wrote docker-compose.yml"
  fi
  files+=(docker-compose.yml)
  mkdir -p .github/workflows
  cat > .github/workflows/deploy.yml <<YML
name: deploy
# SAFETY: only push to your branch + manual dispatch. Do NOT add pull_request —
# on a public repo that lets a fork run code on your self-hosted runner.
on:
  push:
    branches: [$branch]
  workflow_dispatch:
concurrency:
  group: deploy-\${{ github.ref }}
  cancel-in-progress: true
jobs:
  deploy:
    runs-on: [self-hosted, $label]
    steps:
      - uses: actions/checkout@v4
$( ds=$(cfg dotenv_secret); [ -n "$ds" ] && printf '      - name: Provision .env from secret\n        env:\n          DOTENV: ${{ secrets.%s }}\n        run: printf '"'"'%%s'"'"' "$DOTENV" > .env' "$ds" )
      - run: docker compose up -d --build --remove-orphans
$( [ "$(cfg prune_images)" = true ] && printf '      - run: docker image prune -f' )
$( ds=$(cfg dotenv_secret); [ -n "$ds" ] && printf '      - name: Remove provisioned .env\n        if: always()\n        run: rm -f .env' )
YML
  files+=(.github/workflows/deploy.yml)
  log "wrote .github/workflows/deploy.yml"
  cat > "$REPO_CONF" <<CONF
# pideploy per-repo config — safe to commit (NO secrets here).
app_name=$app
default_port=$port
default_branch=$branch
CONF
  [ -n "$dotenv_secret" ] && printf 'dotenv_secret=%s\n' "$dotenv_secret" >> "$REPO_CONF"
  files+=("$REPO_CONF")
  log "wrote $REPO_CONF"
  if ! { [ -f .gitignore ] && grep -qE '^\.env$|^\*\.env$|^\.env\*' .gitignore; }; then
    printf '\n# pideploy: never commit secrets\n.env\n*.env\n!*.env.example\n' >> .gitignore
    log "updated .gitignore (.env protected)"
  fi

  # publish -----------------------------------------------------------------
  local f to_add=() pushed=false
  for f in Dockerfile docker-compose.yml compose.yaml .github/workflows/deploy.yml "$REPO_CONF" .gitignore; do
    [ -e "$f" ] && to_add+=("$f")
  done
  [ ${#to_add[@]} -gt 0 ] && git add "${to_add[@]}" 2>/dev/null || true
  if git diff --cached --quiet 2>/dev/null; then
    log "no changes to commit"
  else
    require_git_identity
    git commit -q -m "Add pideploy: build & deploy on push"
    if git push -q 2>/dev/null; then pushed=true; log "pushed (first deploy starting)"; else warn "committed but push failed; run: git push"; fi
  fi

  # result on stdout --------------------------------------------------------
  if [ "$FORMAT" = json ]; then
    local jf="" sep=""
    for f in "${files[@]}"; do jf+="$sep$(json_str "$f")"; sep=,; done
    printf '{"repo":%s,"app":%s,"port":%s,"branch":%s,"runner":%s,"runner_registered":%s,"pushed":%s,"files":[%s]}\n' \
      "$(json_str "$nwo")" "$(json_str "$app")" "$port" "$(json_str "$branch")" \
      "$(json_str "pi-$slug")" "$(json_bool "$registered")" "$(json_bool "$pushed")" "$jf"
  else
    printf 'repo=%s\napp=%s\nport=%s\nbranch=%s\nrunner=pi-%s\nrunner_registered=%s\npushed=%s\n' \
      "$nwo" "$app" "$port" "$branch" "$slug" "$registered" "$pushed"
  fi
  if [ "$do_serve" = true ]; then
    if [ -n "$rhost" ]; then warn "remote mode: expose it on the host with  ssh $rhost 'pideploy serve --port $port'"
    else cmd_serve "$port"; fi
  fi
  return 0
}

# register a self-hosted runner FOR a repo ON THIS HOST (factored from init).
runner_register() { # nwo slug  -> 0 newly registered · 1 already present
  local nwo="$1" slug="$2"
  ensure_template; install_unit
  if systemctl --user is-active --quiet "pideploy-runner@$slug" >/dev/null 2>&1 \
     || gh api "repos/$nwo/actions/runners" -q '.runners[].name' 2>/dev/null | grep -qx "pi-$slug"; then
    return 1
  fi
  local rdir="$RUNNERS_DIR/$slug" token
  rm -rf "$rdir"; mkdir -p "$rdir"; cp -a "$TEMPLATE_DIR/." "$rdir/"
  token=$(gh api -X POST "repos/$nwo/actions/runners/registration-token" -q .token) || die "registration token failed (need gh 'repo' scope)"
  ( cd "$rdir" && ./config.sh --unattended --replace --url "https://github.com/$nwo" \
      --token "$token" --name "pi-$slug" --labels "$(cfg runner_label)" --work _work >/dev/null )
  systemctl --user enable --now "pideploy-runner@$slug"
  return 0
}

cmd_register() { # host-side: register a runner for <owner/repo>; resolve+record its port
  local nwo="" port=""
  while [ $# -gt 0 ]; do case "$1" in
    --port) port="$2"; shift 2;;
    --*) usage_err "register: unknown flag: $1";;
    *) [ -z "$nwo" ] && nwo="$1"; shift;;
  esac; done
  [ -n "$nwo" ] || usage_err "usage: pideploy register <owner/repo> [--port N]"
  need gh; need docker
  local slug app recorded; slug=$(repo_slug "$nwo"); app="${nwo##*/}"; recorded=$(port_reg_get "$slug")
  if [ -n "$port" ]; then
    port_in_use "$port" "$slug" "$app" && die "port $port already in use on this host (free: $(port_alloc "$slug" "$app"))"
  elif [ -n "$recorded" ]; then port="$recorded"
  else port=$(port_alloc "$slug" "$app"); fi
  port_reg_set "$slug" "$port"
  local registered=false
  if runner_register "$nwo" "$slug"; then registered=true; log "runner pi-$slug installed and started"
  else log "runner pi-$slug already registered"; fi
  linger_on || warn "linger is OFF on this host; runners stop on reboot (sudo loginctl enable-linger $USER)"
  if [ "$FORMAT" = json ]; then
    printf '{"repo":%s,"runner":%s,"port":%s,"label":%s,"registered":%s}\n' \
      "$(json_str "$nwo")" "$(json_str "pi-$slug")" "$port" "$(json_str "$(cfg runner_label)")" "$(json_bool "$registered")"
  else printf 'runner=pi-%s\nport=%s\nlabel=%s\nregistered=%s\n' "$slug" "$port" "$(cfg runner_label)" "$registered"; fi
}

_serve_fail() { # consume /tmp/pd.err -> well-formed error, exit nonzero
  local detail; detail=$(tr '\n' ' ' < /tmp/pd.err | sed 's/  */ /g; s/^ *//; s/ *$//')
  warn "if access denied, run once: sudo tailscale set --operator=$USER"
  emit_err "serve failed: ${detail:-unknown}" 1
  return 1
}
_norm_path() { # normalize to a single leading slash, no trailing slash ("/" stays "/")
  local p="/${1#/}"; p="${p%/}"; [ -z "$p" ] && p="/"; printf '%s' "$p"
}
# default the serve path/port from the repo: path=/<app_name>, port=repo's port
_serve_path() { local p="$1"; [ -z "$p" ] && { local a; a=$(cfg app_name); [ -n "$a" ] && p="/$a" || p="/"; }; _norm_path "$p"; }

cmd_serve() {
  local port="" path="" port_mode=false
  while [ $# -gt 0 ]; do case "$1" in
    --path) path="$2"; shift 2;;
    --port-mode) port_mode=true; shift;;
    --*) usage_err "serve: unknown flag: $1";;
    *) [ -z "$port" ] && port="$1"; shift;;
  esac; done
  need tailscale
  [ -n "$port" ] || port=$(cfg default_port)
  [ -n "$port" ] || usage_err "usage: pideploy serve [port] [--path /name] [--port-mode]"
  local host url; host=$(tailnet_host)

  if [ "$port_mode" = true ]; then
    # own HTTPS port: app gets the root of https://host:<port>/ (no sub-path needed)
    url="https://${host:-localhost}:$port/"
    log "exposing 127.0.0.1:$port at $url (port mode)"
    tailscale serve --bg --https="$port" "$port" >/dev/null 2>/tmp/pd.err \
      || sudo -n tailscale serve --bg --https="$port" "$port" >/dev/null 2>>/tmp/pd.err || { _serve_fail; return 1; }
    if [ "$FORMAT" = json ]; then printf '{"url":%s,"port":%s,"path":%s}\n' "$(json_str "$url")" "$port" '"/"'
    else printf '%s\n' "$url"; fi
  else
    # path-based on :443 — many apps coexist at https://host/<path>
    path=$(_serve_path "$path")
    local sargs=(--bg --https=443); [ "$path" != "/" ] && sargs+=(--set-path="$path")
    url="https://${host:-localhost}${path}"
    log "exposing 127.0.0.1:$port at $url (path mode)"
    tailscale serve "${sargs[@]}" "$port" >/dev/null 2>/tmp/pd.err \
      || sudo -n tailscale serve "${sargs[@]}" "$port" >/dev/null 2>>/tmp/pd.err || { _serve_fail; return 1; }
    if [ "$FORMAT" = json ]; then printf '{"url":%s,"port":%s,"path":%s}\n' "$(json_str "$url")" "$port" "$(json_str "$path")"
    else printf '%s\n' "$url"; fi
  fi
}

cmd_unserve() {
  local port="" path="" port_mode=false
  while [ $# -gt 0 ]; do case "$1" in
    --path) path="$2"; shift 2;;
    --port-mode) port_mode=true; shift;;
    --*) usage_err "unserve: unknown flag: $1";;
    *) [ -z "$port" ] && port="$1"; shift;;
  esac; done
  need tailscale
  if [ "$port_mode" = true ]; then
    [ -n "$port" ] || port=$(cfg default_port)
    tailscale serve --https="$port" off 2>/dev/null || sudo -n tailscale serve --https="$port" off 2>/dev/null || true
    log "stopped serving https port $port"
  else
    path=$(_serve_path "$path")
    if [ "$path" = "/" ]; then
      tailscale serve --https=443 off 2>/dev/null || sudo -n tailscale serve --https=443 off 2>/dev/null || true
    else
      tailscale serve --https=443 --set-path="$path" off 2>/dev/null || sudo -n tailscale serve --https=443 --set-path="$path" off 2>/dev/null || true
    fi
    log "stopped serving $path"
  fi
}

cmd_url() { # print the endpoint for the current repo's app (served URL, else local)
  local open=false; [ "${1:-}" = "--open" ] && open=true
  local host port app served_path="" url="" local_url
  host=$(tailnet_host); port=$(cfg default_port); app=$(cfg app_name)
  [ -n "$port" ] || die "no port known — run inside a repo (with .pideploy.conf) or 'pideploy ports'"
  local_url="http://127.0.0.1:$port/"
  # is this app's port currently served over Tailscale? find its path
  served_path=$(tailscale serve status 2>/dev/null | awk -v p="127.0.0.1:$port" '$0 ~ p {for(i=1;i<=NF;i++) if(substr($i,1,1)=="/"){print $i; exit}}')
  [ -n "$served_path" ] && { url="https://${host:-localhost}${served_path}"; [ "$served_path" = "/" ] && url="https://${host:-localhost}/"; }
  if [ "$FORMAT" = json ]; then
    printf '{"app":%s,"port":%s,"local":%s,"served":%s,"url":%s,"path":%s}\n' \
      "$(json_str "$app")" "$port" "$(json_str "$local_url")" "$([ -n "$served_path" ] && echo true || echo false)" \
      "$(json_str "${url:-}")" "$(json_str "${served_path:-}")"
  else
    if [ -n "$url" ]; then printf '%s\n' "$url"
    else printf '%s\n' "$local_url"; warn "not exposed over Tailscale yet — run: pideploy serve"; fi
  fi
  [ "$open" = true ] && [ -n "${url:-}" ] && command -v xdg-open >/dev/null 2>&1 && xdg-open "$url" >/dev/null 2>&1 || true
  return 0
}

cmd_status() {
  # gather ------------------------------------------------------------------
  local dhost phost; dhost=$(cfg deploy_host); phost=$(cfg portainer_url)
  [ -z "$dhost" ] && dhost=$(hostname 2>/dev/null || echo this-host)
  local rnames=() ractive=() snames=() sstatus=() sports=() serve_lines=() linger=false
  if [ -d "$RUNNERS_DIR" ] && compgen -G "$RUNNERS_DIR/*" >/dev/null; then
    local d s
    for d in "$RUNNERS_DIR"/*/; do s=$(basename "$d"); rnames+=("$s")
      if systemctl --user is-active --quiet "pideploy-runner@$s" >/dev/null 2>&1; then ractive+=(true); else ractive+=(false); fi
    done
  fi
  local line
  while IFS='|' read -r n st pt; do [ -n "$n" ] || continue; snames+=("$n"); sstatus+=("$st"); sports+=("$pt"); done \
    < <(docker ps --format '{{.Names}}|{{.Status}}|{{.Ports}}' 2>/dev/null || true)
  while IFS= read -r line; do [ -n "$line" ] && serve_lines+=("$line"); done \
    < <(tailscale serve status 2>/dev/null | grep -E '^https://' || true)
  linger_on && linger=true

  # emit --------------------------------------------------------------------
  if [ "$FORMAT" = json ]; then
    local i sep out='{"runners":['
    sep=""; for i in "${!rnames[@]}"; do out+="$sep{\"name\":$(json_str "${rnames[$i]}"),\"active\":$(json_bool "${ractive[$i]}")}"; sep=,; done
    out+='],"stacks":['
    sep=""; for i in "${!snames[@]}"; do out+="$sep{\"name\":$(json_str "${snames[$i]}"),\"status\":$(json_str "${sstatus[$i]}"),\"ports\":$(json_str "${sports[$i]}")}"; sep=,; done
    out+='],"serve":['
    sep=""; for i in "${!serve_lines[@]}"; do out+="$sep$(json_str "${serve_lines[$i]}")"; sep=,; done
    out+="],\"linger\":$(json_bool "$linger"),\"deploy_host\":$(json_str "$dhost"),\"portainer_url\":$(json_str "$phost")}"
    printf '%s\n' "$out"
  else
    local i
    printf 'target\t%s\n' "$dhost"
    [ -n "$phost" ] && printf 'portainer\t%s\n' "$phost"
    if [ ${#rnames[@]} -eq 0 ]; then printf 'runner\t(none)\n'; else
      for i in "${!rnames[@]}"; do printf 'runner\t%s\t%s\n' "${rnames[$i]}" "$([ "${ractive[$i]}" = true ] && echo active || echo inactive)"; done
    fi
    for i in "${!snames[@]}"; do printf 'stack\t%s\t%s\t%s\n' "${snames[$i]}" "${sstatus[$i]}" "${sports[$i]}"; done
    for i in "${!serve_lines[@]}"; do printf 'serve\t%s\n' "${serve_lines[$i]}"; done
    printf 'linger\t%s\n' "$([ "$linger" = true ] && echo enabled || echo disabled)"
  fi
}

cmd_logs() {
  local app="${1:-}"
  [ -z "$app" ] && app=$(docker ps --format '{{.Names}}' | head -1)
  [ -z "$app" ] && die "no running containers"
  exec docker logs -f --tail 100 "$app"
}

cmd_deploy() {
  local nwo; nwo=$(resolve_repo)
  if gh workflow run deploy.yml 2>/dev/null; then
    log "deploy dispatched for $nwo"
    [ "$FORMAT" = json ] && printf '{"dispatched":true,"repo":%s}\n' "$(json_str "$nwo")" || printf 'dispatched=true\n'
  else
    warn "workflow_dispatch failed; pushing empty commit"
    require_git_identity
    git commit -q --allow-empty -m "pideploy: trigger deploy" && git push -q
    log "pushed empty commit"
    [ "$FORMAT" = json ] && printf '{"dispatched":true,"method":"push","repo":%s}\n' "$(json_str "$nwo")" || printf 'dispatched=true\n'
  fi
}

cmd_env() { # sync local .env (source of truth) to a GitHub Actions secret
  local name=""
  while [ $# -gt 0 ]; do case "$1" in --name) name="$2"; shift 2;; *) usage_err "env: unknown flag: $1";; esac; done
  need gh
  local nwo; nwo=$(resolve_repo)
  [ -f .env ] || die "no .env in this repo (the source of truth for secrets)"
  local secret="${name:-$(cfg dotenv_secret)}"; secret="${secret:-PIDEPLOY_DOTENV}"
  gh secret set "$secret" --repo "$nwo" < .env || die "gh secret set failed (need admin on $nwo)"
  log "synced .env -> GitHub secret $secret for $nwo"
  if [ "$FORMAT" = json ]; then printf '{"secret":%s,"repo":%s}\n' "$(json_str "$secret")" "$(json_str "$nwo")"
  else printf 'secret=%s\n' "$secret"; fi
}

cmd_onboard() { # clone a repo onto this host and run init (= add it to the pipeline)
  local url="${1:-}"; [ -n "$url" ] || usage_err "usage: pideploy onboard <git-url|owner/repo> [init flags]"
  shift
  need git; need gh
  local base="${PIDEPLOY_REPOS:-$HOME/pideploy-repos}"; mkdir -p "$base"
  local name dest; name=$(basename "${url%.git}"); dest="$base/$name"
  if [ -d "$dest/.git" ]; then log "repo present at $dest (pulling)"; git -C "$dest" pull -q --ff-only 2>/dev/null || true
  else log "cloning $url -> $dest"
       gh repo clone "$url" "$dest" -- -q 2>/dev/null || git clone -q "$url" "$dest" || die "clone failed: $url"; fi
  ( cd "$dest" && cmd_init "$@" )
}

cmd_config() {
  local sub="${1:-list}"; shift || true
  case "$sub" in
    list|"")
      if [ "$FORMAT" = json ]; then
        local k sep out='{'; sep=""
        for k in $(printf '%s\n' "${!CFG[@]}" | sort); do out+="$sep$(json_str "$k"):$(json_str "${CFG[$k]}")"; sep=,; done
        printf '%s}\n' "$out"
      else
        local k; for k in $(printf '%s\n' "${!CFG[@]}" | sort); do printf '%s=%s\n' "$k" "${CFG[$k]}"; done
      fi ;;
    get) [ -n "${1:-}" ] || usage_err "usage: pideploy config get <key>"; printf '%s\n' "$(cfg "$1")" ;;
    set) [ -n "${1:-}" ] && [ -n "${2:-}" ] || usage_err "usage: pideploy config set <key> <value>"
         CFG[$1]="$2"; config_save; log "set $1=$2" ;;
    edit) mkdir -p "$CONFIG_DIR"; [ -f "$CONFIG_FILE" ] || config_save; "${EDITOR:-nano}" "$CONFIG_FILE" ;;
    template) config_template ;;
    path) printf '%s\n' "$CONFIG_FILE" ;;
    *) usage_err "config: list | get <k> | set <k> <v> | edit | template | path" ;;
  esac
}

config_template() { # emit a shareable, placeholder host config (NO real values)
  cat <<'TPL'
# pideploy host config — copy to ~/.config/pideploy/config and fill in your values.
# Scoped to THIS host; reused by every repo you onboard here.
# SAFE TO SHARE only as this placeholder template — never commit real values.

# A friendly name for this deploy target (shown in `pideploy status`).
deploy_host=

# Label that routes GitHub Actions jobs to THIS host's runner. Use a unique
# value (e.g. my-pi) if more than one host serves the same repos.
runner_label=pideploy

# Portainer URL on this host (for reference/links in `pideploy status`).
# Deploys run via `docker compose`; Portainer sees them on the shared engine.
portainer_url=

# Defaults applied to every repo you onboard (override per-repo in .pideploy.conf).
default_port=8080
default_branch=main
auto_serve=false
prune_images=true

# Base image versions for scaffolded Dockerfiles.
node_version=22
python_version=3.12
go_version=1.23

# Optional: default GitHub Actions secret name a repo's .env is synced to.
# Leave commented to keep it per-repo (set automatically when a .env exists).
# dotenv_secret=PIDEPLOY_DOTENV

# REMOTE MODE (set this on a DEV machine, not the host): SSH target of your deploy
# host. When set, 'pideploy init' registers the runner on the host over SSH and only
# scaffolds + pushes locally — so you can onboard repos from your laptop. Needs
# Tailscale SSH (or any SSH) to the host. Leave blank on the host itself.
# runner_host=you@your-pi
TPL
}

cmd_rm() {
  local nwo slug; nwo=$(resolve_repo); slug=$(repo_slug "$nwo")
  systemctl --user disable --now "pideploy-runner@$slug" 2>/dev/null || true
  local rdir="$RUNNERS_DIR/$slug" token
  if [ -x "$rdir/config.sh" ]; then
    token=$(gh api -X POST "repos/$nwo/actions/runners/remove-token" -q .token 2>/dev/null || true)
    [ -n "$token" ] && ( cd "$rdir" && ./config.sh remove --token "$token" >/dev/null 2>&1 || true )
  fi
  rm -rf "$rdir"
  port_reg_del "$slug"   # free its port for reuse
  log "removed runner pi-$slug (workflow file kept in repo)"
  printf 'removed=pi-%s\n' "$slug"
}

cmd_ports() { # list the host port registry (which repo uses which port)
  local s p
  if [ "$FORMAT" = json ]; then
    local sep="" out='{'
    if [ -f "$PORTS_FILE" ]; then while IFS='=' read -r s p; do [ -n "$s" ] && { out+="$sep$(json_str "$s"):$p"; sep=,; }; done < "$PORTS_FILE"; fi
    printf '%s}\n' "$out"
  else
    [ -f "$PORTS_FILE" ] && sort "$PORTS_FILE" || true
  fi
}

cmd_setup() {
  log "one-time host prep (idempotent)"
  if linger_on; then log "linger: already enabled"
  elif sudo -n loginctl enable-linger "$USER" 2>/dev/null; then log "linger: enabled"
  else warn "linger: run manually -> sudo loginctl enable-linger $USER"; fi
  if sudo -n tailscale set --operator="$USER" 2>/dev/null; then log "tailscale operator: set to $USER"
  else warn "tailscale operator: run manually -> sudo tailscale set --operator=$USER"; fi
  log "now run: pideploy doctor"
}

cmd_doctor() {
  local names=() oks=() sev=() allok=true
  add() { names+=("$1"); oks+=("$2"); sev+=("${3:-fatal}")
          [ "$2" = true ] || { [ "${3:-fatal}" = fatal ] && allok=false; }; return 0; }
  local b; for b in git gh docker curl tar systemctl loginctl tailscale; do
    command -v "$b" >/dev/null 2>&1 && add "$b" true || add "$b" false
  done
  gh auth status >/dev/null 2>&1 && add gh-auth true || add gh-auth false
  { require_git_identity >/dev/null 2>&1; } && add git-identity true || add git-identity false
  id -nG | tr ' ' '\n' | grep -qx docker && add docker-group true || add docker-group false
  systemctl --user is-system-running >/dev/null 2>&1 && add user-systemd true || add user-systemd false
  docker info >/dev/null 2>&1 && add docker-engine true || add docker-engine false
  command -v tailscale >/dev/null 2>&1 && { tailscale status >/dev/null 2>&1 && add tailscale-up true || add tailscale-up false warn; }
  linger_on && add linger true || add linger false warn

  local i
  if [ "$FORMAT" = json ]; then
    local sep out='{"checks":['
    sep=""; for i in "${!names[@]}"; do out+="$sep{\"name\":$(json_str "${names[$i]}"),\"ok\":$(json_bool "${oks[$i]}"),\"severity\":$(json_str "${sev[$i]}")}"; sep=,; done
    out+="],\"ok\":$(json_bool "$allok")}"; printf '%s\n' "$out"
  else
    for i in "${!names[@]}"; do
      if [ "${oks[$i]}" = true ]; then printf '%-16s ok\n' "${names[$i]}"
      elif [ "${sev[$i]}" = warn ]; then printf '%-16s WARN\n' "${names[$i]}"
      else printf '%-16s FAIL\n' "${names[$i]}"; fi
    done
  fi
  [ "$allok" = true ] || return 1
}

# ── agent manual ─────────────────────────────────────────────────────────────
cmd_agent() {
  cat <<'AGENT'
# pideploy — Agent Operating Manual

Deploys any git repo to this host: on every push, a self-hosted GitHub Actions
runner builds the repo's Docker image and runs it via docker compose. Containers
appear in Portainer (same Docker engine) and can be exposed on the tailnet over
HTTPS. This CLI is plain and non-interactive.

## Output contract
- Primary data -> STDOUT. Plain `key=value` or tab-separated rows; add `--json`
  for structured JSON on: init, status, deploy, serve, url, ports, config, env,
  register, doctor.
- Progress/warnings/errors -> STDERR (`pideploy:` / `warn:` / `error:`). In `--json`
  mode, errors are a JSON object on STDERR: `{"error":"<msg>","code":<N>}`. On any
  error STDOUT stays empty.
- Exit codes: 0 ok · 1 runtime error · 2 usage error.
- Never prompts; reads no stdin. Safe to run unattended.

## Architecture
- One self-hosted runner per repo, as user systemd service
  `pideploy-runner@<owner-repo>` (no root; needs `loginctl enable-linger` once).
- Runner connects OUTBOUND to GitHub, so the host needs no inbound ports and
  works tailnet-only. GitHub webhooks cannot reach it — do not use them.
- Deploys run `docker compose up -d --build`; Portainer shares the Docker engine.
- Exposure: `pideploy serve` (Tailscale HTTPS); apps bind 127.0.0.1 only. Many apps
  coexist via distinct paths on https://<host>/ (see "Exposing multiple apps").

## How the deploy is routed (no address/SSH — label matching)
There is NO IP, hostname, SSH key, or target in the repo. `init` registers a
runner on THIS host with GitHub, labeled `[self-hosted, Linux, <arch>, <runner_label>]`.
The workflow's `runs-on: [self-hosted, <runner_label>]` is a label requirement, not
an address; GitHub dispatches the job to the matching runner — i.e. this host.
Move the runner elsewhere and the same push deploys there; the repo is unchanged.

## Local vs remote mode (where init registers the runner)
- Local (default): run `init` ON the deploy host; it registers the runner there.
- Remote: set `runner_host=you@host` (config) on a dev machine; `init` SSHes to the
  host and runs `pideploy register <repo>` there (which assigns the port + returns
  the label), then only scaffolds + pushes locally. So you can onboard repos from a
  laptop with no Docker/systemd. The host must have pideploy + SSH (e.g. Tailscale SSH).
  On a personal GitHub account a runner is still per-repo; remote mode just automates
  the host-side registration over SSH (an org would let one runner serve all repos).

## Deploy pipeline (runs on the host for each push to the branch)
1. `actions/checkout@v4` — clone the repo into the runner workdir.
2. (if a .env secret is configured) Provision .env: `printf '%s' "$DOTENV" > .env`
   where DOTENV=`secrets.<NAME>` (GitHub-masked).
3. `docker compose up -d --build --remove-orphans` — build + (re)start containers.
4. `docker image prune -f` (if prune_images) — drop dangling layers.
5. (if .env secret) Remove provisioned .env with `if: always()`.
Result: containers run on the host's Docker engine (visible in Portainer);
`pideploy serve <port>` exposes one over Tailscale HTTPS.

## Prerequisites (verify: `pideploy doctor`, or `pideploy doctor --json`)
- gh authenticated, scopes `repo` + `workflow`.
- git identity set to a real address you control — `git config --global user.email`
  (and `user.name`). `init`/`deploy` refuse to commit with an unset or generic
  identity (e.g. `noreply@users.noreply.github.com`), which GitHub mis-attributes to
  whatever account claimed it. `doctor` reports this as `git-identity`.
- user in `docker` group; user systemd running; docker engine reachable.
- `sudo loginctl enable-linger $USER` (persist runners) — or run `pideploy setup`.
- tailscale up; `sudo tailscale set --operator=$USER` (serve without sudo).

## Commands
- `pideploy setup` — best-effort one-time host prep (linger, tailscale operator).
- `pideploy doctor [--json]` — prerequisite check; exit 1 if any fatal check fails.
- `pideploy init [--port N] [--name NAME] [--serve] [--json]` — in a git repo with
  a GitHub remote: scaffold Dockerfile/compose/workflow + `.pideploy.conf`,
  register+start the runner, commit & push. Emits repo/app/port/runner/pushed.
- `pideploy onboard <git-url|owner/repo> [init flags]` — clone the repo onto THIS
  host then init it (registers the runner here so it deploys here). Run on the host.
- `pideploy register <owner/repo> [--port N] [--json]` — host-side: register a runner
  for a repo + assign its port. Used by remote-mode init (laptop SSHes here).
- `pideploy deploy [--json]` — trigger a deploy now.
- `pideploy status [--json]` — runners, stacks, serve, linger.
- `pideploy serve [port] [--path /name] [--port-mode] [--json]` — expose a port over
  Tailscale HTTPS; prints the URL on stdout. Path-based by default (many apps coexist).
- `pideploy unserve [port] [--path /name] [--port-mode]` — remove one app's route.
- `pideploy url [--json]` / `pideploy open` — print (or open) THIS repo's app endpoint:
  the served https URL if exposed, else the local http://127.0.0.1:<port>/.
- `pideploy logs [app]` — exec `docker logs -f` (stdout passthrough).
- `pideploy config [list|get <k>|set <k> <v>|edit] [--json]` — manage defaults.
- `pideploy ports [--json]` — list the host port registry (repo→port).
- `pideploy env [--name NAME] [--json]` — sync local .env to a GitHub Actions secret.
- `pideploy rm` — deregister this repo's runner.
- `pideploy skill` — print a Claude Code skill for this CLI (also: `--skill`).
- `pideploy help [command]` — overview, or detailed help + options for one command.
- `pideploy version` · `pideploy --agent` (print this manual).

Global flags: `--json` (structured output), `--agent` (this manual), `--skill`
(the skill), `--yes` (accepted, no-op).

## Config & precedence
Flags > per-repo `.pideploy.conf` > HOST config `$XDG_CONFIG_HOME/pideploy/config` > built-in.
The HOST config is global to this machine and reused by every repo onboarded here
(one config, many repos). It lives OUTSIDE any repo, so it never leaks. Generate a
shareable placeholder with `pideploy config template` (commit that, never the real one).
Host keys: deploy_host, portainer_url, runner_label, default_port, default_branch,
auto_serve, prune_images, node_version, python_version, go_version.
Repo keys (.pideploy.conf): app_name, dotenv_secret.
New host setup: `pideploy config template > ~/.config/pideploy/config` then edit.

## Files written into a repo by init
- `Dockerfile` (only if missing; node/python/go/static autodetect).
- `docker-compose.yml` (build: ., binds 127.0.0.1:<port>, top-level name:=stack).
- `.github/workflows/deploy.yml` (runs-on [self-hosted, <label>]; push + dispatch only).
- `.pideploy.conf` (port/name/branch; safe to commit, no secrets).
- appends `.env` to `.gitignore`.

## Ports (no collisions across repos)
A host-wide registry ($PIDEPLOY_HOME/ports, <owner-repo>=<port>) keeps every app on
a distinct, stable port. `init` auto-assigns the lowest free port at/above default_port
(8080) when --port is omitted; an explicit --port is rejected (exit 1) if another app
already uses it. Re-init reuses the repo's recorded port; `rm` frees it. See `pideploy ports`.

## Exposing multiple apps (path-based, no collisions)
`serve` is path-based on https://<host>:443 by default: each app mounts at a distinct
path (default /<app_name>) via `tailscale serve --set-path`, so many apps coexist:
  https://<host>/api -> :8080 · https://<host>/web -> :8081 · https://<host>/bot -> :8082
In a repo, `pideploy serve` needs no args (port from .pideploy.conf, path from app_name).
Caveat: the app must tolerate a sub-path (relative links / configurable base URL). If it
can't, use `--port-mode` to serve it at https://<host>:<port>/ (its own HTTPS port, root).
`unserve` removes just one route. Tailscale routing is unrelated to deploy targeting.

## Secrets (.env)
A local `.env` is the source of truth. When present, `init` uploads it to a GitHub
Actions secret (`gh secret set`, default name PIDEPLOY_DOTENV) and the generated
workflow recreates `.env` on the runner before `docker compose up`. `.env` is never
committed. Re-sync after editing it with `pideploy env`. Skip with `--no-dotenv`.

## Agent quickstart (deploy a repo end-to-end)
1. cd <repo>  (needs GitHub remote; else: gh repo create --source=. --private --push)
2. pideploy doctor --json    # ensure "ok":true; if not, pideploy setup
3. pideploy init --port <app-port> --json
4. pideploy status --json    # confirm runner active and a stack is up
5. pideploy serve <app-port> # stdout is the https URL
Redeploy after changes: git push   (or: pideploy deploy)

## Troubleshooting
- runner inactive: systemctl --user status pideploy-runner@<owner-repo>; enable linger.
- unreachable app: ensure it listens on <port> and compose maps 127.0.0.1:<port>:<port>.
- serve "access denied": sudo tailscale set --operator=$USER.
- no remote / push rejected: gh repo create first; check gh scopes repo+workflow.
AGENT
}

# ── per-command help (rich, AI-readable) ─────────────────────────────────────
cmd_help() {
  local c="${1:-}"
  case "$c" in
    "") usage; return 0;;
    init) cat <<'H'
pideploy init — set up the current git repo to deploy on every push.

Run inside a git repo that has a GitHub remote. Idempotent: re-running keeps
existing files and skips runner registration. Scaffolds Dockerfile (if missing),
docker-compose.yml, .github/workflows/deploy.yml, and .pideploy.conf; registers a
per-repo self-hosted runner as a user systemd service; commits and pushes (which
triggers the first deploy).

USAGE
  pideploy init [--port N] [--name NAME] [--serve|--no-serve]
                [--dotenv-secret NAME|--no-dotenv] [--json]

OPTIONS
  --port N             Host port to bind on 127.0.0.1 (collision-checked). Omit to AUTO-ASSIGN
                       the lowest free port at/above default_port (8080) — apps never collide.
                       The choice is recorded in the host registry (see: pideploy ports).
  --name NAME          App / Docker-compose stack / container name (default: .pideploy.conf app_name, else repo name).
  --serve              After deploy, expose the port over Tailscale HTTPS immediately.
  --no-serve           Do not expose (overrides config auto_serve).
  --dotenv-secret NAME GitHub Actions secret name to sync .env into (default: PIDEPLOY_DOTENV when a .env exists).
  --no-dotenv          Do not sync .env to a secret even if one exists.
  --json               Emit the result object {repo,app,port,branch,runner,runner_registered,pushed,files}.

SECRETS
  If a .env exists, init treats it as the source of truth: it uploads it to a
  GitHub Actions secret via 'gh secret set', and the generated workflow recreates
  .env from that secret on the runner before 'docker compose up'. Re-sync after
  editing .env with 'pideploy env'.

REMOTE MODE
  Set 'runner_host=you@your-pi' (config) on a dev machine and init registers the
  runner on the host over SSH, then only scaffolds + pushes locally — so you can
  onboard repos from your laptop (no Docker/systemd needed there). Needs SSH to the
  host (e.g. Tailscale SSH) and pideploy installed there.

OUTPUT
  stdout: key=value result (or JSON). stderr: progress (pideploy: ...).
EXAMPLES
  pideploy init --port 3000
  pideploy init --name api --serve --json
H
;;
    deploy) cat <<'H'
pideploy deploy — trigger a deploy of the current repo now (without code changes).

Dispatches the deploy workflow via the GitHub API; if that fails, pushes an empty
commit instead. Run inside the repo.

USAGE   pideploy deploy [--json]
OUTPUT  stdout: dispatched=true (or JSON {dispatched,repo}). stderr: progress.
H
;;
    status) cat <<'H'
pideploy status — show the deploy state on this host.

USAGE   pideploy status [--json]
OUTPUT (text, tab-separated rows on stdout):
  target    <deploy_host>             this deploy target (config deploy_host, else hostname)
  portainer <url>                     Portainer URL, if configured
  runner    <name> <active|inactive>  one row per registered repo runner
  stack     <name> <status> <ports>   one row per running container
  serve     <url>                     each Tailscale HTTPS proxy
  linger    <enabled|disabled>        whether user services persist across reboot
  --json: {runners:[{name,active}], stacks:[{name,status,ports}], serve:[..],
           linger:bool, deploy_host:str, portainer_url:str}
H
;;
    serve) cat <<'H'
pideploy serve — expose a local port over Tailscale with HTTPS (tailnet-only).

Apps bind 127.0.0.1; this fronts them with a real TLS cert reachable from your
tailnet (and nowhere else). MANY apps can be served at once: each gets a distinct
path on https://<host>/ — so they never collide.

USAGE   pideploy serve [port] [--path /name] [--port-mode] [--json]

OPTIONS
  port         Local port to expose (default: the current repo's port, from .pideploy.conf).
  --path /name URL path to mount at (default: /<app_name> in a repo, else /). Each app
               at a distinct path coexists: https://<host>/api, https://<host>/web, ...
  --port-mode  Instead of a path, serve at https://<host>:<port>/ (the app gets the root
               of its own HTTPS port). Use when an app can't handle a sub-path.
  --json       Emit {url, port, path}.

OUTPUT  stdout: the https URL. stderr: progress.
NOTE    Needs Tailscale HTTPS enabled + `sudo tailscale set --operator=$USER` (see: pideploy setup).
EXAMPLES
  pideploy serve                 # in a repo: https://<host>/<app_name>
  pideploy serve 8080 --path /api
  pideploy serve 8080 --port-mode    # https://<host>:8080/
H
;;
    unserve) cat <<'H'
pideploy unserve — remove ONE app's Tailscale route (others stay up).
Mirrors serve's resolution: path-based by default (default path /<app_name>);
--port-mode removes the https://<host>:<port>/ mapping instead.
USAGE   pideploy unserve [port] [--path /name] [--port-mode]
H
;;
    logs) cat <<'H'
pideploy logs — tail a deployed app's container logs (follows; Ctrl-C to stop).
USAGE   pideploy logs [app]      # app defaults to the first running container
H
;;
    url|open) cat <<'H'
pideploy url — print THIS repo's app endpoint. If the app's port is currently
served over Tailscale, prints that https URL; otherwise prints the local
http://127.0.0.1:<port>/ and reminds you to `pideploy serve`. `pideploy open`
does the same and launches it in a browser (if one is available).

USAGE   pideploy url [--json]      # run inside the repo (uses .pideploy.conf)
        pideploy open
OUTPUT  stdout: the URL (or JSON {app,port,local,served,url,path}).
H
;;
    env) cat <<'H'
pideploy env — sync the local .env (source of truth) to a GitHub Actions secret.

Uploads ./.env via `gh secret set` so the deploy workflow can recreate it on the
runner before `docker compose up`. `init` does this automatically when a .env is
present; run `env` again after editing .env. Never commits .env (it's gitignored).

USAGE   pideploy env [--name NAME]        # default secret: PIDEPLOY_DOTENV (or .pideploy.conf dotenv_secret)
OUTPUT  stdout: secret=<NAME> (or JSON {secret,repo}); stderr: progress.
H
;;
    register) cat <<'H'
pideploy register — (host-side) register a self-hosted runner for a repo on THIS
host and assign/record its port. Mostly used internally by remote-mode `init`
(your laptop SSHes here and calls this). You can also run it directly on the host.

USAGE   pideploy register <owner/repo> [--port N] [--json]
OUTPUT  runner=pi-<owner-repo> · port=<n> · label=<runner_label> · registered=<bool>
H
;;
    onboard) cat <<'H'
pideploy onboard — clone a repo onto THIS host and init it in one step.

Run on the deploy host. Clones the repo into $PIDEPLOY_REPOS (default
~/pideploy-repos/<name>), then runs `pideploy init` there — registering the
runner on this host so the repo deploys here. Accepts all `init` flags.

USAGE   pideploy onboard <git-url|owner/repo> [--port N] [--name NAME] [--serve] [--no-dotenv]
EXAMPLE pideploy onboard me/my-api --port 3000
H
;;
    config) cat <<'H'
pideploy config — view or change settings. The HOST config is global
(~/.config/pideploy/config) and is reused by every repo you onboard on this host.

Precedence (highest first): CLI flags > per-repo .pideploy.conf > host config > built-in.

USAGE
  pideploy config list [--json]      Show effective config.
  pideploy config get <key>          Print one value.
  pideploy config set <key> <value>  Persist a host default.
  pideploy config edit               Open the host config in $EDITOR.
  pideploy config template           Print a shareable placeholder host config (no real values).
  pideploy config path               Print the host config file path.

HOST KEYS  deploy_host, portainer_url, runner_label, default_port, default_branch,
           auto_serve, prune_images, node_version, python_version, go_version.
REPO KEYS  app_name, dotenv_secret (written to .pideploy.conf by init).
DEV KEY    runner_host=you@your-pi — set on a laptop to enable REMOTE MODE: 'init'
           registers the runner on the host over SSH (onboard repos from anywhere).

SETUP (new host):  pideploy config template > ~/.config/pideploy/config  &&  pideploy config edit
H
;;
    rm) cat <<'H'
pideploy rm — deregister this repo's self-hosted runner and remove its service.
Leaves the workflow file in the repo; frees its port in the host registry.
Re-run `pideploy init` to recreate.
USAGE   pideploy rm
H
;;
    ports) cat <<'H'
pideploy ports — list the host port registry (which repo is assigned which port).

pideploy keeps every onboarded app on a distinct, stable host port so deploys
never collide. `init` auto-assigns the lowest free port at/above default_port
(8080) unless you pass --port (which is collision-checked). `rm` frees a port.

USAGE   pideploy ports [--json]
OUTPUT  text: '<owner-repo>=<port>' lines; --json: {"<owner-repo>": <port>, ...}
H
;;
    setup) cat <<'H'
pideploy setup — best-effort one-time host preparation (idempotent).
Enables systemd linger (so runners survive reboot) and sets the Tailscale
operator (so serve needs no sudo). Prints manual commands for anything it
cannot do without a password. Then run `pideploy doctor`.
USAGE   pideploy setup
H
;;
    doctor) cat <<'H'
pideploy doctor — check every prerequisite; exit 1 if any FATAL check fails.

Checks binaries (git, gh, docker, curl, tar, systemctl, loginctl, tailscale),
gh auth, git-identity (a real user.email/name is set), docker group membership,
user systemd, docker engine, tailscale up, and linger. tailscale-up and linger
are WARN (non-fatal).

USAGE   pideploy doctor [--json]
OUTPUT  text: "<check> ok|WARN|FAIL"; --json: {checks:[{name,ok,severity}], ok}
H
;;
    agent) cat <<'H'
pideploy agent — print the full operating manual for AI agents (also: --agent).
USAGE   pideploy agent
H
;;
    skill) cat <<'H'
pideploy skill — print a Claude Code skill (markdown w/ frontmatter) teaching an
agent to use this CLI: directives, rules, workflow, troubleshooting. Also: --skill.
Save it to .claude/skills/pideploy/SKILL.md to install.
USAGE   pideploy skill > .claude/skills/pideploy/SKILL.md
H
;;
    help) cat <<'H'
pideploy help — show the overview, or detailed help for one command.
USAGE   pideploy help [command]      # also: pideploy <command> --help
H
;;
    version) cat <<'H'
pideploy version — print the CLI version.
USAGE   pideploy version            # also: pideploy --version
H
;;
    *) usage_err "no help for command: $c (try: pideploy help)";;
  esac
}

# ── skill (Claude Code skill document) ───────────────────────────────────────
cmd_skill() {
  cat <<'SKILL'
---
name: pideploy
description: Use when deploying a git repo to a self-hosted Docker host (Raspberry Pi) via the `pideploy` CLI — set up push-to-deploy, check deploy status, expose apps over Tailscale, or troubleshoot a runner. Triggers: "deploy this to my pi", "set up push-to-deploy", "expose this app over tailscale", "why isn't my deploy running".
---

# Deploying with the pideploy CLI

`pideploy` turns any git repo into push-to-deploy on a self-hosted Docker host: a
per-repo self-hosted GitHub Actions runner builds the repo's Docker image on push
and runs it via docker compose. Apps appear in Portainer and are exposed over
Tailscale HTTPS. The CLI is plain and non-interactive — ideal to drive directly.

## How it routes & deploys
No IP/SSH/target is configured. `init` registers a runner on the host labeled
`[self-hosted, …, <runner_label>]`; the workflow's `runs-on: [self-hosted, <runner_label>]`
makes GitHub dispatch the job to THAT runner (label match, not an address). The
runner dials GitHub outbound, so the host needs no open ports. Each push runs, on
the host: checkout → (provision .env from secret) → `docker compose up -d --build`
→ prune → (remove .env). Containers land on the host's Docker engine (Portainer
sees them); `serve` exposes a port over Tailscale.

## First, read the manual
Run `pideploy --agent` for the authoritative reference, and `pideploy help <command>`
for any command's options. Do not guess flags — confirm with `help`.

## Host config (one config, many repos)
This host has a global config at `~/.config/pideploy/config` (deploy_host, runner_label,
portainer_url, defaults). It is reused by every repo onboarded here and lives outside
any repo, so it never leaks. New host: `pideploy config template > ~/.config/pideploy/config`
then edit. NEVER commit a real host config or .env — only the placeholder template.

## Local vs remote mode
Run `init` ON the host (local), or set `runner_host=you@host` on a dev machine for
REMOTE mode: `init` SSHes to the host, runs `pideploy register <repo>` there to enroll
the runner + assign the port, then scaffolds + pushes locally. Lets you onboard repos
from a laptop (no Docker/systemd needed locally). Needs SSH to the host + pideploy there.

## Output contract (rely on this)
- Data → STDOUT (`key=value`/rows, or JSON with `--json`). Parse stdout.
- Progress/warnings/errors → STDERR (`pideploy:`/`warn:`/`error:`). With `--json`,
  errors are `{"error":"<msg>","code":<N>}` on STDERR; STDOUT stays empty on error.
- Exit codes: 0 ok · 1 runtime error · 2 usage error. Always check them.
- Never prompts. Prefer `--json` when parsing programmatically.

## Rules / directives
- ALWAYS run `pideploy doctor --json` first and ensure `"ok":true`. If not, run
  `pideploy setup`, then re-check. Do not proceed past FATAL checks.
- A real git identity MUST be set (`git config --global user.email`/`user.name`).
  `init`/`deploy` refuse to commit with an unset or generic identity (e.g.
  `noreply@users.noreply.github.com`) — GitHub mis-attributes such commits to a
  stranger's account. `doctor` reports it as `git-identity` (FATAL).
- The repo MUST have a GitHub remote before `init`. If missing, run
  `gh repo create --source=. --private --push` first.
- Apps MUST listen on the port `init` uses (pass `--port`, or let it auto-assign)
  and compose maps `127.0.0.1:<port>:<port>`. Mismatch = unreachable.
- Ports never collide: `init` auto-assigns a free, stable port per repo (registry).
  Omit `--port` to auto-assign; an explicit taken `--port` fails. See `pideploy ports`.
- Expose many apps at once: `pideploy serve` is path-based (each app at https://<host>/<app>).
  In a repo it needs no args. If an app can't handle a sub-path, use `--port-mode`
  (https://<host>:<port>/). `unserve` removes one route.
- NEVER add a `pull_request` trigger to the generated workflow on a public repo —
  it would let a fork run code on the self-hosted runner.
- NEVER commit secrets. A local `.env` is the source of truth: `init` syncs it to
  a GitHub Actions secret (`gh secret set`, default PIDEPLOY_DOTENV) and the workflow
  recreates `.env` on the runner before compose up. Re-sync after edits: `pideploy env`.
  `.env` is gitignored. Skip syncing with `--no-dotenv`.
- One runner per repo (personal GitHub accounts can't share runners).

## Standard workflow (end-to-end)
1. `pideploy doctor --json`            → verify prerequisites (else `pideploy setup`).
2. `cd <repo>`                         → ensure a GitHub remote exists.
3. `pideploy init --port <P> --json`   → scaffold, register runner, push (first deploy).
4. `pideploy status --json`            → confirm runner active and stack is up.
5. `pideploy serve <P>`                → stdout is the public https URL.
6. `pideploy url`                      → reprint this app's endpoint anytime.
- Redeploy after changes: `git push` (or `pideploy deploy`).
- Tear down a repo's runner: `pideploy rm`.

## Troubleshooting
- runner inactive (status): `systemctl --user status pideploy-runner@<owner-repo>`;
  ensure linger is on (`pideploy setup` or `sudo loginctl enable-linger $USER`).
- app unreachable after deploy: verify the in-container listen port matches `--port`
  and the compose port mapping; then `pideploy serve <port>`.
- `serve` "access denied": `sudo tailscale set --operator=$USER` (or `pideploy setup`).
- no HTTPS cert: enable HTTPS Certificates in the Tailscale admin console.
- init fails "no GitHub remote": `gh repo create --source=. --private --push`.
- deploys never trigger: check `gh auth status` includes `repo` + `workflow` scopes.

## Command quick reference
`setup` host prep · `doctor` prereqs · `config template` host config · `init` set up repo ·
`onboard <repo>` clone+init on host · `register <repo>` host-side runner enroll (remote mode) ·
`deploy` redeploy now · `status` state · `serve`/`unserve` expose · `url`/`open` app endpoint ·
`logs` tail · `config` defaults · `ports` port registry · `env` sync .env→secret · `rm` remove runner ·
`agent` · `skill` · `help <cmd>`.
Add `--json` to init/status/deploy/serve/url/ports/config/env/register/doctor.
SKILL
}

usage() {
  cat <<EOF
pideploy v$PIDEPLOY_VERSION — push-to-deploy for a self-hosted Docker host

>> AI AGENTS: run \`pideploy --agent\` for the full operating manual before using
   this tool, then \`pideploy help <command>\` for any command's options.

WHAT IT IS
  A plain, scriptable CLI that turns any git repo into push-to-deploy on a
  machine you own (built for a Raspberry Pi). No cloud, no inbound ports.

HOW IT WORKS
  'init' scaffolds a Dockerfile/compose/workflow and registers a per-repo,
  self-hosted GitHub Actions runner on the DEPLOY HOST. On every push, GitHub
  dispatches the job to that runner — so it always builds and 'docker compose up's
  ON THE HOST, never on whatever machine you ran the CLI from. The runner connects
  OUTBOUND to GitHub, so the host needs no open ports and works tailnet-only. Portainer shares the Docker engine (sees your apps);
  'serve' exposes apps over Tailscale HTTPS (path-based, so many coexist). Each repo
  gets a distinct, stable port (no collisions). Run 'init' on the host, or from a
  laptop in REMOTE mode ('config set runner_host you@host') — it then registers the
  runner on the host over SSH and just scaffolds + pushes.

GETTING STARTED  (do this first)
  1. pideploy setup                      prepare this host (linger + tailscale)  [once]
  2. pideploy doctor                     confirm prerequisites are ok
  3. cd <your-repo>                      a repo with a GitHub remote
  4. pideploy init --port <port>         scaffold + register runner + first deploy
  5. pideploy serve <port>               expose over Tailscale (prints the URL)
  Then just 'git push' to redeploy.

FOR AI AGENTS
  pideploy --agent                       full operating manual (read this first)
  pideploy --skill > .claude/skills/pideploy/SKILL.md    install a Claude Code skill
  pideploy help <command>                detailed help + options for one command

USAGE
  pideploy <command> [args] [--json]

COMMANDS
  init [--port N] [--name NAME] [--serve]   set up the current repo to deploy on push
  onboard <git-url|owner/repo>              clone a repo onto this host + init it (one step)
  deploy                                    trigger a deploy now (no code change needed)
  status                                    list runners, running stacks, serve, linger
  serve [port] [--path /p] [--port-mode]    expose over Tailscale HTTPS (path-based; many apps coexist)
  unserve                                   stop exposing one app's route
  url | open                                print (or open) this app's endpoint URL
  logs [app]                                tail a deployed app's container logs
  config list|get|set|edit|template|path    view/change defaults; 'template' prints a host-config example
  register <owner/repo>                     (host) register a runner for a repo — used by remote-mode init
  ports                                     list which repo uses which port (host registry)
  env [--name NAME]                         sync local .env -> GitHub Actions secret
  rm                                        remove this repo's runner
  setup                                     one-time host prep (linger, tailscale operator)
  doctor                                    check prerequisites (exit 1 if any fail)
  agent                                     print the full manual for AI agents
  skill                                     print a Claude Code skill for this CLI
  version | help [command]                  version, or detailed help for a command

FLAGS
  --json    structured output (init, status, deploy, serve, url, ports, config, env, register, doctor)
  --agent   print the agent manual          --skill  print the agent skill
  --yes     accepted (no-op; CLI never prompts)

Detailed help:  pideploy help <command>      Full manual:  pideploy --agent
EOF
}

# ── dispatch ──────────────────────────────────────────────────────────────────
main() {
  local args=() a want_help=0
  for a in "$@"; do case "$a" in
    --json) FORMAT=json;;
    --agent) cmd_agent; exit 0;;
    --skill) cmd_skill; exit 0;;
    --help|-h) want_help=1;;
    --yes|-y|--no-color) ;;                 # accepted, no-op
    *) args+=("$a");;
  esac; done
  load_config
  mkdir -p "$PIDEPLOY_HOME" "$RUNNERS_DIR"

  local cmd="${args[0]:-help}"; [ ${#args[@]} -gt 0 ] && args=("${args[@]:1}") || args=()
  # `pideploy <cmd> --help` and `pideploy -h` show detailed help
  [ "$want_help" = 1 ] && { [ "$cmd" = help ] && cmd_help || cmd_help "$cmd"; exit 0; }
  case "$cmd" in
    init)    cmd_init    "${args[@]}";;
    register) cmd_register "${args[@]}";;
    deploy)  cmd_deploy  "${args[@]}";;
    status)  cmd_status  "${args[@]}";;
    serve)   cmd_serve   "${args[@]}";;
    unserve) cmd_unserve "${args[@]}";;
    url)     cmd_url     "${args[@]}";;
    open)    cmd_url --open "${args[@]}";;
    logs)    cmd_logs    "${args[@]}";;
    config)  cmd_config  "${args[@]}";;
    env)     cmd_env     "${args[@]}";;
    ports)   cmd_ports   "${args[@]}";;
    onboard) cmd_onboard "${args[@]}";;
    rm)      cmd_rm      "${args[@]}";;
    setup)   cmd_setup   "${args[@]}";;
    doctor)  cmd_doctor  "${args[@]}";;
    agent)   cmd_agent;;
    skill)   cmd_skill;;
    help)    cmd_help "${args[@]}";;
    version|--version|-v) printf 'pideploy %s\n' "$PIDEPLOY_VERSION";;
    *) usage_err "unknown command: $cmd (try: pideploy help)";;
  esac
}

if [ "${PIDEPLOY_LIB:-0}" != "1" ]; then main "$@"; fi
